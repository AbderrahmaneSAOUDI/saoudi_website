					<div class="absolute inset-0 bg-gradient-to-br from-secondary/5 via-transparent to-secondary/5 blur-3xl"></div>
					<div class="relative bg-surface-container border border-white/10 rounded-3xl p-8 shadow-2xl hover:shadow-secondary/10 transition-all duration-300 h-full">
						<h2 class="text-3xl font-bold text-primary mb-6 flex items-center gap-3">
							Education
