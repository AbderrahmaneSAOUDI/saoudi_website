---
/**
 * Main Landing Page (Home)
 * Displays the hero section.
 * Uses BaseLayout for the main site wrapper and provides animated entry sections.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import {
	ChartNoAxesCombined,
	Check,
	Cog,
	Mail,
	Medal,
	Palette,
	Phone,
	Plug,
	Toolbox,
} from '@lucide/astro';
---

<BaseLayout title="Home">
	<div class="mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-1 max-w-7xl">
		<!-- Hero Section -->
		<section class="animate-fade-in flex items-center py-5">
			<div class="relative w-full">
				<div class="absolute inset-0 bg-gradient-to-tr from-primary/5 via-transparent to-secondary/5 blur-3xl"></div>
				
				<div class="relative bg-surface/30 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-12 lg:p-16 shadow-2xl">
					<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
						<div class="flex justify-center lg:justify-start">
							<div class="relative">
								<div class="absolute inset-0 bg-gradient-to-br from-primary/30 to-secondary/30 rounded-full blur-2xl animate-photo-halo"></div>
								<div class="hero-photo-light" aria-hidden="true"></div>
								<div class="relative w-48 h-48 md:w-64 md:h-64 lg:w-72 lg:h-72 rounded-full border-4 border-primary/40 shadow-2xl shadow-primary/20 overflow-hidden bg-gradient-to-br from-primary/10 to-secondary/10">
									<img 
										src="/profile.webp" 
										alt="Abderrahmane SAOUDI Profile Picture"
										class="w-full h-full object-cover border-4 border-primary rounded-full"
									/>
								</div>
							</div>
						</div>
						
						<div class="text-center lg:text-left lg:col-span-2">
							<h1 class="mb-4 font-bold text-white text-4xl md:text-5xl lg:text-6xl">
								Hi, I'm <span class="text-primary">Abderrahmane SAOUDI</span>
							</h1>
							<p class="text-white/80 text-xl md:text-2xl mb-8 leading-relaxed font-light">
								Passionate technologist and community leader crafting digital experiences
							</p>
							
							<div class="space-y-6">
								<div class="space-y-3 pt-4">
									<h3 class="text-white/60 text-sm font-semibold uppercase tracking-wider">Professional Roles</h3>
									<div class="flex flex-wrap justify-center lg:justify-start gap-2">
										<span class="px-4 py-2 bg-primary/10 text-primary border border-primary/20 rounded-xl text-sm font-semibold">n8n Developer</span>
										<span class="px-4 py-2 bg-primary/10 text-primary border border-primary/20 rounded-xl text-sm font-semibold">Mobile Developer</span>
										<span class="px-4 py-2 bg-primary/10 text-primary border border-primary/20 rounded-xl text-sm font-semibold">Graphic Designer</span>
									</div>
								</div>
								
								<div class="space-y-3 pt-4">
									<h3 class="text-white/60 text-sm font-semibold uppercase tracking-wider">Community & Leadership</h3>
									<div class="flex flex-wrap justify-center lg:justify-start gap-2">
										<span class="px-4 py-2 bg-secondary/10 text-secondary border border-secondary/20 rounded-xl text-sm font-semibold">GDG Ghardaia President (2022-Now)</span>
										<span class="px-4 py-2 bg-secondary/10 text-secondary border border-secondary/20 rounded-xl text-sm font-semibold">University Teacher</span>
										<span class="px-4 py-2 bg-secondary/10 text-secondary border border-secondary/20 rounded-xl text-sm font-semibold">DevFest Lead 2023-2025</span>
										<span class="px-4 py-2 bg-secondary/10 text-secondary border border-secondary/20 rounded-xl text-sm font-semibold">Google I/O Lead 2023-2025</span>
									</div>
								</div>
								
								<div class="space-y-3 pt-4">
									<h3 class="text-white/60 text-sm font-semibold uppercase tracking-wider">Achievements</h3>
									<div class="flex flex-wrap justify-center lg:justify-start gap-2">
										<span class="inline-flex items-center gap-2 px-4 py-2 bg-tertiary/10 text-tertiary border border-tertiary/20 rounded-xl text-sm font-semibold">
											<Medal class="w-4 h-4" aria-hidden="true" />
											3rd Place - StartUp City Hackathon
										</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Me & Education Row -->
		<div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
			<!-- Professional Summary -->
			<section class="animate-fade-in" style="animation-delay: 0.2s;">
				<div class="relative h-full">
					<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/5 blur-3xl"></div>
					<div class="relative bg-surface-container border border-white/10 rounded-3xl overflow-hidden shadow-2xl hover:shadow-primary/10 transition-all duration-300 h-full flex flex-col">
						<img src="/cover.webp" alt="Profile" class="w-full h-48 object-cover" />
						<div class="p-8 flex-1">
							<h2 class="text-3xl md:text-4xl font-bold text-primary mb-6 flex items-center gap-3">
								About Me
							</h2>
							<div class="text-white/80 text-lg leading-relaxed">
								<p class="mb-4">
									I am a Computer Science Master's student from Ghardaia, Algeria, driven by software engineering and tech community leadership.
								</p>
								<p>
									Beyond engineering, I serve as the volunteer President of GDG Ghardaia, managing a structured team to run events and tech sessions (online and in-person).
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Education Timeline -->
			<section class="animate-fade-in" style="animation-delay: 0.3s;">
				<div class="relative h-full">
					<div class="absolute inset-0 bg-gradient-to-br from-secondary/5 via-transparent to-secondary/5 blur-3xl"></div>
					<div class="relative bg-surface-container border border-white/10 rounded-3xl p-8 shadow-2xl hover:shadow-secondary/10 transition-all duration-300 h-full">
						<h2 class="text-3xl md:text-4xl font-bold text-primary mb-6 flex items-center gap-3">
							Education
						</h2>
						<div class="relative">
							<!-- Timeline Line -->
							<div class="absolute left-[15px] top-0 bottom-0 w-0.5 bg-primary/35 overflow-hidden">
								<!-- Animated Gradient Line -->
								<div class="absolute inset-0 bg-primary rounded-full animate-timeline-progress"></div>
								<!-- Electricity Dots -->
								<div class="electric-dot w-2 h-2 bg-primary rounded-full shadow-lg shadow-primary/60 absolute left-1/2"></div>
								<div class="electric-dot w-1.5 h-1.5 bg-secondary rounded-full shadow-lg shadow-secondary/60 absolute left-1/2" style="animation-delay: 0.6s;"></div>
								<div class="electric-dot w-1 h-1 bg-tertiary rounded-full shadow-lg shadow-tertiary/60 absolute left-1/2" style="animation-delay: 1.2s;"></div>
							</div>
							
							<div class="space-y-8 pl-8">
								<!-- Item 1 -->
								<div class="relative">
									<div class="absolute -left-[25px] top-2 w-4 h-4 rounded-full bg-primary border-2 border-surface z-10 shadow-lg shadow-primary/30 animate-dot-pulse"></div>
									<div class="bg-surface-container-high border border-white/10 rounded-2xl p-5 hover:border-primary/30 transition-all duration-300">
										<h3 class="text-lg font-bold text-white">University of Ghardaia</h3>
										<p class="text-primary font-semibold">Master of Science in Intelligent Systems for Knowledge Extraction</p>
										<p class="text-white/60 mt-1">Ongoing (1st Year)</p>
									</div>
								</div>
								<!-- Item 2 -->
								<div class="relative">
									<div class="absolute -left-[25px] top-2 w-4 h-4 rounded-full bg-secondary border-2 border-surface z-10 shadow-lg shadow-secondary/30 animate-dot-pulse" style="animation-delay: 0.3s;"></div>
									<div class="bg-surface-container-high border border-white/10 rounded-2xl p-5 hover:border-secondary/30 transition-all duration-300">
										<h3 class="text-lg font-bold text-white">University of Ghardaia</h3>
										<p class="text-secondary font-semibold">Bachelor of Science in Information Systems (SI)</p>
										<p class="text-white/60 mt-1">Graduated June 2022</p>
									</div>
								</div>
								<!-- Item 3 -->
								<div class="relative">
									<div class="absolute -left-[25px] top-2 w-4 h-4 rounded-full bg-tertiary border-2 border-surface z-10 shadow-lg shadow-tertiary/30 animate-dot-pulse" style="animation-delay: 0.6s;"></div>
									<div class="bg-surface-container-high border border-white/10 rounded-2xl p-5 hover:border-tertiary/30 transition-all duration-300">
										<h3 class="text-lg font-bold text-white">Algerian Red Crescent</h3>
										<p class="text-tertiary font-semibold">First Aid Trainee</p>
										<p class="text-white/60 mt-1">Completed April 2026</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		</div>

		<!-- Technical Skills -->
		<section class="mt-8 animate-fade-in" style="animation-delay: 0.5s;">
			<div class="relative">
				<div class="absolute inset-0 bg-gradient-to-br from-secondary/5 via-transparent to-secondary/5 blur-3xl"></div>
				<div class="relative bg-surface-container border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl hover:shadow-secondary/10 transition-all duration-300 overflow-hidden">
					<div class="absolute -top-20 right-0 w-56 h-56 bg-secondary/10 blur-3xl rounded-full"></div>
					<div class="relative">
						<div class="flex flex-wrap items-end justify-between gap-4 mb-8">
							<div>
								<h2 class="text-3xl md:text-4xl font-bold text-primary flex items-center gap-3">
									Technical Skills
								</h2>
							</div>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-12 gap-5">
							<div class="xl:col-span-5 bg-surface-container-high border border-secondary/20 rounded-2xl p-6 hover:border-secondary/40 transition-all duration-300 hover:-translate-y-1 group">
								<div class="flex items-center justify-between mb-4">
									<h3 class="text-secondary font-bold text-xl">Development</h3>
									<Cog class="w-6 h-6 text-primary" aria-hidden="true" />
								</div>
								<div class="flex flex-wrap gap-2.5">
									<span class="px-3 py-1.5 bg-secondary/10 text-secondary border border-secondary/25 rounded-lg text-sm font-medium">Mobile development</span>
									<span class="px-3 py-1.5 bg-secondary/10 text-secondary border border-secondary/25 rounded-lg text-sm font-medium">WordPress CMS customization</span>
									<span class="px-3 py-1.5 bg-secondary/10 text-secondary border border-secondary/25 rounded-lg text-sm font-medium">UI/UX implementation</span>
								</div>
							</div>

							<div class="xl:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-5">
								<div class="bg-surface-container-high border border-primary/20 rounded-2xl p-5 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1">
									<div class="flex items-center justify-between mb-3">
										<h3 class="text-primary font-bold text-lg">Automation</h3>
										<Plug class="w-5 h-5 text-primary" aria-hidden="true" />
									</div>
									<div class="flex flex-wrap gap-2">
										<span class="px-2.5 py-1 bg-primary/10 text-primary border border-primary/20 rounded-md text-xs">n8n workflow design</span>
										<span class="px-2.5 py-1 bg-primary/10 text-primary border border-primary/20 rounded-md text-xs">Notion automation</span>
										<span class="px-2.5 py-1 bg-primary/10 text-primary border border-primary/20 rounded-md text-xs">event management systems</span>
									</div>
								</div>

								<div class="bg-surface-container-high border border-tertiary/20 rounded-2xl p-5 hover:border-tertiary/40 transition-all duration-300 hover:-translate-y-1">
									<div class="flex items-center justify-between mb-3">
										<h3 class="text-tertiary font-bold text-lg">Design</h3>
										<Palette class="w-5 h-5 text-primary" aria-hidden="true" />
									</div>
									<div class="flex flex-wrap gap-2">
										<span class="px-2.5 py-1 bg-tertiary/10 text-tertiary border border-tertiary/20 rounded-md text-xs">Adobe Illustrator</span>
										<span class="px-2.5 py-1 bg-tertiary/10 text-tertiary border border-tertiary/20 rounded-md text-xs">Figma</span>
										<span class="px-2.5 py-1 bg-tertiary/10 text-tertiary border border-tertiary/20 rounded-md text-xs">brand identity creation</span>
										<span class="px-2.5 py-1 bg-tertiary/10 text-tertiary border border-tertiary/20 rounded-md text-xs">promotional design</span>
									</div>
								</div>

								<div class="bg-surface-container-high border border-error/20 rounded-2xl p-5 hover:border-error/40 transition-all duration-300 hover:-translate-y-1">
									<div class="flex items-center justify-between mb-3">
										<h3 class="text-error font-bold text-lg">Business</h3>
										<ChartNoAxesCombined class="w-5 h-5 text-primary" aria-hidden="true" />
									</div>
									<div class="flex flex-wrap gap-2">
										<span class="px-2.5 py-1 bg-error/10 text-error border border-error/20 rounded-md text-xs">Design analysis</span>
										<span class="px-2.5 py-1 bg-error/10 text-error border border-error/20 rounded-md text-xs">social media analytics</span>
										<span class="px-2.5 py-1 bg-error/10 text-error border border-error/20 rounded-md text-xs">event operations</span>
										<span class="px-2.5 py-1 bg-error/10 text-error border border-error/20 rounded-md text-xs">partnership management</span>
									</div>
								</div>

								<div class="bg-surface-container-high border border-primary/20 rounded-2xl p-5 hover:border-primary/40 transition-all duration-300 hover:-translate-y-1">
									<div class="flex items-center justify-between mb-3">
										<h3 class="text-primary font-bold text-lg">Tools</h3>
										<Toolbox class="w-5 h-5 text-primary" aria-hidden="true" />
									</div>
									<div class="flex flex-wrap gap-2">
										<span class="px-2.5 py-1 bg-primary/10 text-primary border border-primary/20 rounded-md text-xs">Microsoft Office Suite</span>
										<span class="px-2.5 py-1 bg-primary/10 text-primary border border-primary/20 rounded-md text-xs">Google Workspace</span>
										<span class="px-2.5 py-1 bg-primary/10 text-primary border border-primary/20 rounded-md text-xs">event management platforms</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Soft Skills & Languages -->
		<section class="mt-8 animate-fade-in" style="animation-delay: 0.6s;">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
				<div class="relative">
					<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/5 blur-3xl"></div>
					<div class="relative bg-surface-container border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl hover:shadow-primary/10 transition-all duration-300">
						<h2 class="text-3xl md:text-4xl font-bold text-primary mb-6 flex items-center gap-3">
							Soft Skills
						</h2>
						<ul class="space-y-3">
							<li class="flex items-center gap-3 text-white/80">
								<Check class="w-4 h-4 text-primary shrink-0" aria-hidden="true" />
								Team leadership & people management
							</li>
							<li class="flex items-center gap-3 text-white/80">
								<Check class="w-4 h-4 text-primary shrink-0" aria-hidden="true" />
								Rapid learning & cross-functional adaptability
							</li>
							<li class="flex items-center gap-3 text-white/80">
								<Check class="w-4 h-4 text-primary shrink-0" aria-hidden="true" />
								Cross-team collaboration & stakeholder communication
							</li>
							<li class="flex items-center gap-3 text-white/80">
								<Check class="w-4 h-4 text-primary shrink-0" aria-hidden="true" />
								Large-scale event planning & execution
							</li>
							<li class="flex items-center gap-3 text-white/80">
								<Check class="w-4 h-4 text-primary shrink-0" aria-hidden="true" />
								Creative problem solving
							</li>
							<li class="flex items-center gap-3 text-white/80">
								<Check class="w-4 h-4 text-primary shrink-0" aria-hidden="true" />
								End-to-end project responsibility
							</li>
						</ul>
					</div>
				</div>
				
				<div class="relative">
					<div class="absolute inset-0 bg-gradient-to-br from-secondary/5 via-transparent to-secondary/5 blur-3xl"></div>
					<div class="relative bg-surface-container border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl hover:shadow-secondary/10 transition-all duration-300">
						<h2 class="text-3xl md:text-4xl font-bold text-primary mb-6 flex items-center gap-3">
							Languages
						</h2>
						<div class="space-y-4">
							<div>
								<div class="flex justify-between mb-2">
									<span class="text-white font-semibold">Arabic</span>
									<span class="text-white/70">Native</span>
								</div>
								<div class="h-2 bg-white/10 rounded-full overflow-hidden">
									<div class="h-full bg-primary rounded-full w-full"></div>
								</div>
							</div>
							<div>
								<div class="flex justify-between mb-2">
									<span class="text-white font-semibold">English</span>
									<span class="text-white/70">Intermediate (B1)</span>
								</div>
								<div class="h-2 bg-white/10 rounded-full overflow-hidden">
									<div class="h-full bg-secondary rounded-full w-2/3"></div>
								</div>
							</div>
							<div>
								<div class="flex justify-between mb-2">
									<span class="text-white font-semibold">French</span>
									<span class="text-white/70">Basic</span>
								</div>
								<div class="h-2 bg-white/10 rounded-full overflow-hidden">
									<div class="h-full bg-tertiary rounded-full w-1/3"></div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Information -->
		<section class="mt-8 animate-fade-in" style="animation-delay: 0.4s;">
			<div class="relative">
				<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-tertiary/5 blur-3xl"></div>
				<div class="relative bg-surface-container border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl hover:shadow-primary/10 transition-all duration-300">
					<h2 class="text-3xl md:text-4xl font-bold text-primary mb-8 flex items-center gap-3">
						Contact
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="bg-surface-container-high border border-white/10 rounded-2xl p-6 flex items-start gap-4 hover:border-primary/30 transition-all duration-300 hover:-translate-y-1">
							<div class="w-12 h-12 bg-primary/20 rounded-xl flex items-center justify-center text-primary flex-shrink-0 shadow-lg shadow-primary/10">
								<Phone class="w-6 h-6" aria-hidden="true" />
							</div>
							<div>
								<h3 class="text-white font-semibold">Phone</h3>
								<p class="text-white/70">+213 561 37 77 61</p>
								<p class="text-white/70">+213 676 89 56 13</p>
							</div>
						</div>
						<div class="bg-surface-container-high border border-white/10 rounded-2xl p-6 flex items-start gap-4 hover:border-secondary/30 transition-all duration-300 hover:-translate-y-1">
							<div class="w-12 h-12 bg-secondary/20 rounded-xl flex items-center justify-center text-secondary flex-shrink-0 shadow-lg shadow-secondary/10">
								<Mail class="w-6 h-6" aria-hidden="true" />
							</div>
							<div>
								<h3 class="text-white font-semibold">Email</h3>
								<p class="text-white/70">abderrahmane.saoudi.26@gmail.com</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 0.8s ease-out forwards;
	}

	@keyframes photo-halo {
		0%, 100% {
			transform: scale(0.94);
			opacity: 0.55;
		}
		50% {
			transform: scale(1.08);
			opacity: 0.9;
		}
	}

	@keyframes photo-light {
		0%, 100% {
			transform: translateX(-50%) scaleX(0.84);
			opacity: 0.55;
		}
		50% {
			transform: translateX(-50%) scaleX(1.08);
			opacity: 0.95;
		}
	}

	.animate-photo-halo {
		animation: photo-halo 4.5s ease-in-out infinite;
	}

	.hero-photo-light {
		position: absolute;
		z-index: 0;
		left: 50%;
		bottom: -1.25rem;
		width: 82%;
		height: 2.5rem;
		border-radius: 9999px;
		background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-primary) 85%, white 15%), var(--color-secondary), transparent);
		filter: blur(14px);
		animation: photo-light 3.2s ease-in-out infinite;
	}

	@keyframes timeline-progress {
		0% {
			height: 0%;
		}
		100% {
			height: 100%;
		}
	}

	.animate-timeline-progress {
		animation: timeline-progress 1.5s ease-out forwards;
	}

	@keyframes dot-pulse {
		0%, 100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.15);
		}
	}

	.animate-dot-pulse {
		animation: dot-pulse 2s infinite ease-in-out;
	}

	@keyframes electric-flow {
		0% {
			transform: translate(-50%, -14%);
			opacity: 0;
		}
		12% {
			opacity: 1;
		}
		88% {
			opacity: 1;
		}
		100% {
			transform: translate(-50%, 112%);
			opacity: 0;
		}
	}

	@keyframes electric-flicker {
		0%,
		100% {
			filter: brightness(1) saturate(1);
		}
		50% {
			filter: brightness(1.45) saturate(1.25);
		}
	}

	.electric-dot {
		top: 0;
		transform: translate(-50%, -14%);
		animation: electric-flow 2.2s linear infinite, electric-flicker 0.9s ease-in-out infinite;
		will-change: transform, opacity, filter;
	}
</style>
