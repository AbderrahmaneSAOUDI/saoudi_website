<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translate3d(0, 20px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	.animate-fade-in {
		animation: fade-in 0.8s ease-out forwards;
		will-change: transform, opacity;
	}

	@keyframes timeline-progress {
		0% {
			height: 0%;
		}
		100% {
			height: 100%;
		}
	}

	.animate-timeline-progress {
		animation: timeline-progress 1.5s ease-out forwards;
	}

	@keyframes dot-pulse {
		0%, 100% {
			transform: scale3d(1, 1, 1);
		}
		50% {
			transform: scale3d(1.15, 1.15, 1);
		}
	}

	.animate-dot-pulse {
		animation: dot-pulse 2s infinite ease-in-out;
		will-change: transform;
	}

	@keyframes electric-flow {
		0% {
			transform: translate3d(-50%, -14%, 0);
			opacity: 0;
		}
		12% {
			opacity: 1;
		}
		88% {
			opacity: 1;
		}
		100% {
			transform: translate3d(-50%, 112%, 0);
			opacity: 0;
		}
	}

	@keyframes electric-flicker {
		0%,
		100% {
			filter: brightness(1) saturate(1);
		}
		50% {
			filter: brightness(1.45) saturate(1.25);
		}
	}

	.electric-dot {
		top: 0;
		transform: translate3d(-50%, -14%, 0);
		animation: electric-flow 2.2s linear infinite, electric-flicker 0.9s ease-in-out infinite;
		will-change: transform, opacity, filter;
	}

	@keyframes glow-pulse {
		0%, 100% {
			opacity: 0.4;
			transform: translate3d(-50%, 0, 0) scale3d(0.9, 1, 1);
		}
		50% {
			opacity: 0.8;
			transform: translate3d(-50%, 0, 0) scale3d(1.1, 1, 1);
		}
	}

	.animate-glow-pulse {
