			</div>
		</section>

		<!-- Soft Skills & Languages -->
		<section class="mt-12 animate-fade-in" style="animation-delay: 0.6s;">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
				<div class="relative">
					<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/5 blur-3xl"></div>
