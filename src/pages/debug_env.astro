---
import { getEnv } from '../lib/server/env';
import { getFirebaseAdminApp } from '../lib/server/firebase-admin';

let result = '';
let errStack = '';
let privateKeyDetails = '';

const projectId = getEnv('FIREBASE_PROJECT_ID');
const clientEmail = getEnv('FIREBASE_CLIENT_EMAIL');
const privateKey = getEnv('FIREBASE_PRIVATE_KEY');
const storageBucket = getEnv('FIREBASE_STORAGE_BUCKET');

if (privateKey) {
  privateKeyDetails = `Length: ${privateKey.length}, Starts with: "${privateKey.substring(0, 30)}", Ends with: "${privateKey.substring(privateKey.length - 30)}", Contains \\n literal? ${privateKey.includes('\\n')}, Contains actual newlines? ${privateKey.includes('\n')}`;
} else {
  privateKeyDetails = 'MISSING';
}

try {
  const app = getFirebaseAdminApp();
  result = `SUCCESS! App name: ${app.name}`;
} catch (e: any) {
  result = `FAILURE: ${e.message}`;
  errStack = e.stack || '';
}
---
<!DOCTYPE html>
<html>
<head>
  <title>Debug Environment</title>
</head>
<body style="background: #121212; color: #fff; font-family: monospace; padding: 20px;">
  <h1>Debug Environment</h1>
  <p><strong>FIREBASE_PROJECT_ID:</strong> {projectId ? `SET (length ${projectId.length})` : 'MISSING'}</p>
  <p><strong>FIREBASE_CLIENT_EMAIL:</strong> {clientEmail ? `SET (length ${clientEmail.length})` : 'MISSING'}</p>
  <p><strong>FIREBASE_STORAGE_BUCKET:</strong> {storageBucket ? `SET (length ${storageBucket.length})` : 'MISSING'}</p>
  <p><strong>FIREBASE_PRIVATE_KEY Details:</strong> {privateKeyDetails}</p>
  
  <h2>Firebase App Initialization:</h2>
  <pre style="background: #1e1e1e; padding: 15px; border-radius: 8px; border: 1px solid #333; overflow-x: auto;">
{result}
  </pre>

  {errStack && (
    <div>
      <h2>Error Stack Trace:</h2>
      <pre style="background: #1e1e1e; padding: 15px; border-radius: 8px; border: 1px solid #333; color: #ff5555; overflow-x: auto;">
{errStack}
      </pre>
    </div>
  )}
</body>
</html>
