---
import BackgroundBaseLayout from "../../layouts/BackgroundBaseLayout.astro";
import '../../styles/global.css';
import { UserLock } from '@lucide/astro';

const title = "Admin — Login";
const gsiHtml = `
<script src="https://accounts.google.com/gsi/client" async defer></script>
<script>
  function handleCredentialResponse(response) {
    // Send the token to your backend for verification
    fetch('/admin/login', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        credential: response.credential
      })
    })
    .then(res => {
      if (res.ok) {
        window.location.href = '/admin';
      }
    })
    .catch(err => console.error('Login failed:', err));
  }

  window.onload = function () {
    google.accounts.id.initialize({
      client_id: '863682225036-gsh98s9rql7kfvfj2p0kthrnhufbs780.apps.googleusercontent.com',
      callback: handleCredentialResponse
    });
    google.accounts.id.renderButton(
      document.getElementById('g_id_signin'),
      { 
        theme: 'filled_black', 
        size: 'medium',
        width: '100%',
        shape: 'pill',
        text: 'continue_with',
      }
    );
  };
</script>
`;
---

<BackgroundBaseLayout title={title}>
  <main class="min-h-screen flex items-center justify-center">
    <section class="max-w-md" aria-labelledby="login-heading">
      <div class="p-6 rounded-3xl shadow-lg" style="background:var(--color-surface-container); color:var(--color-google-white);">
        <header class="mb-6 text-center flex flex-col items-center">
          <UserLock class="w-12 h-12" style="color:var(--color-primary);" />
        </header>

        <div id="g_id_onload"
        class="rounded-3xl"
          data-client_id="YOUR_GOOGLE_CLIENT_ID"
          data-callback="handleCredentialResponse">
        </div>
        <div class="w-full flex justify-center rounded-3xl" id="g_id_signin" data-type="standard" data-size="medium" data-theme="dark"></div>

        <div set:html={gsiHtml}></div>
      </div>
    </section>
  </main>
</BackgroundBaseLayout>
