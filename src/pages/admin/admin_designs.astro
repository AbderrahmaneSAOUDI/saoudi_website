---
import '../../styles/global.css';

import BackgroundBaseLayout from "../../layouts/BackgroundBaseLayout.astro";
import AdminLayout from "../../components/admin/AdminLayout.astro";
import AdminNavDock from "../../components/admin/AdminNavDock.astro";
import { getFirebaseAdminDb } from "../../lib/server/firebase-admin";
import { Palette, Image as ImageIcon, Trash2, Save, CircleAlert, Settings } from '@lucide/astro';
import Card from "../../components/Card.astro";
import DesignLightbox from "../../components/DesignLightbox.astro";
import AdminControlsStrip from "../../components/admin/AdminControlsStrip.astro";

// Extra safety: double-check authentication
const adminEmail = Astro.locals.adminEmail;
if (!adminEmail) return Astro.redirect("/admin/admin_login");

let designs: any[] = [];
let companies: string[] = ['Google', 'GDG', 'Freelance', 'Personal'];
let years: string[] = [];
let errorMsg = '';

try {
	const db = getFirebaseAdminDb();
	
	// Fetch companies from the database configuration
	const companiesDoc = await db.collection("configuration").doc("designs_companies").get();
	if (companiesDoc.exists) {
		companies = companiesDoc.data()?.companies || companies;
	} else {
		// Auto-initialize companies configuration in DB
		await db.collection("configuration").doc("designs_companies").set({ companies });
	}

	// Sort by Design date descending
	const snapshot = await db.collection("designs").orderBy("date", "desc").get();
	designs = snapshot.docs.map(doc => ({
		id: doc.id,
		...doc.data()
	}));
	
	// Extract unique sorted years
	years = [...new Set(designs.map(d => {
		if (typeof d.date === 'string' && d.date.includes('-')) {
			return d.date.split('-')[0];
		}
		return null;
	}).filter(Boolean))].sort((a, b) => b.localeCompare(a));
} catch (error: any) {
	console.warn("Failed to fetch designs from Firestore:", error);
	errorMsg = "Degraded mode: Firestore is not configured or offline.";
}
---

<BackgroundBaseLayout title="Designs Workspace">
	<AdminLayout title="Designs">
		<div class="relative min-h-[calc(100vh-140px)]">
			
			<!-- Main Left Area: Full width list since panel is drawer -->
			<div class="space-y-6">
				
				<!-- Top Controls Strip -->
				<AdminControlsStrip
					searchId="search-input"
					searchPlaceholder="Search designs by title, company, tags..."
					filterToggleId="btn-filter-toggle"
					filterBadgeId="filter-badge"
					newBtnId="btn-new-design"
					newBtnLabel="New"
				/>

				{errorMsg && (
					<div class="p-4 rounded-2xl bg-[#DB4437]/10 border border-[#DB4437]/30 text-[#DB4437] text-sm flex items-center gap-2.5">
						<CircleAlert class="w-5 h-5 shrink-0" />
						<span>{errorMsg}</span>
					</div>
				)}

				<!-- Grid of Designs -->
				<div id="designs-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4">
					{/* Cards will be dynamically rendered via JS */}
				</div>

				<!-- Load More Button -->
				<div id="load-more-container" class="flex justify-center">
					<button
						id="btn-load-more"
						class="px-6 py-2.5 rounded-xl border border-[#2B2930] hover:bg-[#2B2930] text-[#E6E1E5] font-semibold text-sm transition-all duration-300 cursor-pointer"
					>
						Load More
					</button>
				</div>
			</div>

			<!-- Drawer Backdrop -->
			<div
				id="editor-backdrop"
				class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[60] transition-opacity duration-300 opacity-0"
			></div>

			<!-- Sliding Filter Drawer (Starts offscreen translated left) -->
			<div
				id="filter-panel"
				class="fixed top-0 left-0 h-full w-full sm:w-[360px] bg-[#1D1B20] border-r border-[#2B2930] shadow-2xl transition-transform duration-350 ease-[cubic-bezier(0.2,0,0.2,1)] transform -translate-x-full z-[70] p-6 pb-28 sm:pb-6 overflow-y-auto flex flex-col justify-between"
			>
				<div class="space-y-5">
					<div class="border-b border-[#2B2930]/60 pb-4 flex justify-between items-center">
						<div>
							<h2 class="text-lg font-bold text-white">Filter Designs</h2>
							<p class="text-xs text-[#E6E1E5]/50 mt-1">Refine mockup listing</p>
						</div>
						<button
							type="button"
							id="btn-close-filters"
							class="text-[#E6E1E5]/60 hover:text-white transition-colors cursor-pointer text-xl font-bold"
						>
							&times;
						</button>
					</div>

					<div class="space-y-4">
						<!-- Company Select -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Company</label>
							<select
								id="filter-company"
								class="w-full px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-sm focus:outline-none focus:border-primary transition-colors cursor-pointer"
							>
								<option value="">All Companies</option>
								{companies.map(comp => (
									<option value={comp}>{comp}</option>
								))}
							</select>
						</div>

						<!-- Year Select -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Year</label>
							<select
								id="filter-year"
								class="w-full px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-sm focus:outline-none focus:border-primary transition-colors cursor-pointer"
							>
								<option value="">All Years</option>
								{years.map(y => (
									<option value={y}>{y}</option>
								))}
							</select>
						</div>

						<!-- Date Interval -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Date Interval</label>
							<div class="grid grid-cols-2 gap-2">
								<div>
									<span class="text-[10px] text-[#E6E1E5]/40 mb-1 block">From</span>
									<input
										type="date"
										id="filter-start-date"
										class="w-full px-3 py-2 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-xs focus:outline-none focus:border-primary transition-colors cursor-pointer"
									/>
								</div>
								<div>
									<span class="text-[10px] text-[#E6E1E5]/40 mb-1 block">To</span>
									<input
										type="date"
										id="filter-end-date"
										class="w-full px-3 py-2 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-xs focus:outline-none focus:border-primary transition-colors cursor-pointer"
									/>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="flex gap-3 mt-8 pt-4 border-t border-[#2B2930]/40">
					<button
						type="button"
						id="btn-clear-filters"
						class="w-full py-2.5 bg-transparent border border-[#2B2930] hover:bg-[#2B2930] text-[#E6E1E5]/60 hover:text-white font-semibold rounded-xl text-xs transition-all cursor-pointer text-center"
					>
						Clear Filters
					</button>
				</div>
			</div>

			<!-- Sliding Drawer Detail Editor (Starts offscreen translated right) -->
			<div
				id="editor-panel"
				class="fixed top-0 right-0 h-full w-full sm:w-[460px] bg-[#1D1B20] border-l border-[#2B2930] shadow-2xl transition-transform duration-350 ease-[cubic-bezier(0.2,0,0.2,1)] transform translate-x-full z-[70] p-6 pb-28 sm:pb-6 overflow-y-auto flex flex-col justify-between"
			>
				<div class="space-y-5">
					<div class="border-b border-[#2B2930]/60 pb-4 flex justify-between items-center">
						<div>
							<h2 id="editor-heading" class="text-lg font-bold text-white">Create Design</h2>
							<p id="editor-subheading" class="text-xs text-[#E6E1E5]/50 mt-1">Add a new portfolio entry</p>
						</div>
						<button
							type="button"
							id="btn-delete"
							class="hidden p-2.5 rounded-xl text-[#DB4437] hover:bg-[#DB4437]/10 border border-transparent hover:border-[#DB4437]/20 transition-all cursor-pointer shrink-0"
							title="Delete Design"
						>
							<Trash2 class="w-5 h-5" />
						</button>
					</div>

					<form id="design-form" class="space-y-4" onsubmit="event.preventDefault();">
						
						<!-- Image Dropzone (Moved to the Top) -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Mockup Image *</label>
							<div
								id="image-drop-zone"
								class="border-2 border-dashed border-[#2B2930] hover:border-primary/50 rounded-2xl p-4 text-center transition-all duration-300 cursor-pointer group relative overflow-hidden min-h-[140px] flex flex-col items-center justify-center bg-[#141218]"
							>
								<input
									type="file"
									id="image-file-input"
									accept="image/jpeg,image/png,image/webp"
									class="hidden"
								/>
								
								<!-- Hover/Preview overlay -->
								<img
									id="image-preview"
									src=""
									alt="Preview"
									class="hidden absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-105 transition-all duration-500"
								/>

								<div id="drop-zone-prompt" class="relative z-10 flex flex-col items-center gap-1.5">
									<div class="p-2 rounded-full bg-primary/10 text-primary group-hover:bg-primary/20 transition-colors">
										<ImageIcon class="w-5 h-5" />
									</div>
									<div>
										<p class="text-xs font-medium text-white">
											Drop cover or <span class="text-primary font-semibold">browse</span>
										</p>
										<p class="text-[10px] text-[#E6E1E5]/40 mt-0.5">JPEG, PNG, WebP (Max 10MB)</p>
									</div>
								</div>

								<div id="file-details" class="hidden relative z-10 text-[10px] bg-[#0F9D58]/10 text-[#0F9D58] border border-[#0F9D58]/20 px-2 py-1 rounded-md font-semibold mt-2">
									✓ File Selected
								</div>
							</div>
						</div>

						<!-- Read-only design ID -->
						<div class="hidden">
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Design ID</label>
							<input
								type="text"
								id="form-id"
								name="id"
								readonly
								class="w-full px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-[#E6E1E5]/40 text-xs focus:outline-none"
							/>
						</div>

						<!-- Title -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Title *</label>
							<input
								type="text"
								id="form-title"
								name="title"
								required
								placeholder="e.g., E-Commerce App Dashboard"
								class="w-full px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-sm focus:outline-none focus:border-primary transition-colors"
							/>
						</div>

						<!-- Company Dropdown with Manage Button -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Company *</label>
							<div class="flex gap-2 items-center">
								<select
									id="form-company"
									name="company"
									required
									class="flex-grow px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-sm focus:outline-none focus:border-primary transition-colors cursor-pointer"
								>
									{companies.map(comp => (
										<option value={comp}>{comp}</option>
									))}
								</select>
								<button
									type="button"
									id="btn-edit-companies"
									title="Manage Companies"
									class="p-2.5 rounded-xl border border-[#2B2930] hover:bg-[#2B2930] hover:border-primary/50 text-primary transition-all cursor-pointer flex items-center justify-center shrink-0"
								>
									<Settings class="w-5 h-5" />
								</button>
							</div>
						</div>

						<!-- Date -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Design Date *</label>
							<input
								type="date"
								id="form-date"
								name="date"
								required
								class="w-full px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-sm focus:outline-none focus:border-primary transition-colors cursor-pointer"
							/>
						</div>

						<!-- Tags Field -->
						<div>
							<label class="block text-xs font-semibold text-[#E6E1E5]/70 mb-1.5">Tags (Comma-separated)</label>
							<input
								type="text"
								id="form-tags"
								name="tags"
								placeholder="e.g. figma, dashboard, mobile"
								class="w-full px-4 py-2.5 rounded-xl border border-[#2B2930] bg-[#211F26] text-white text-sm focus:outline-none focus:border-primary transition-colors"
							/>
						</div>

						<!-- Status Panel -->
						<div id="form-status" class="hidden p-3.5 rounded-xl border text-xs font-medium text-center"></div>

						<!-- Form Buttons (Includes Cancel Button) -->
						<div class="flex gap-3 pt-2">
							<button
								type="button"
								id="btn-cancel"
								class="flex-1 py-3 px-4 rounded-xl border border-[#2B2930] hover:bg-[#2B2930] text-[#E6E1E5] font-semibold text-sm transition-all duration-300 cursor-pointer text-center"
							>
								Cancel
							</button>
							<button
								type="submit"
								id="btn-save"
								class="flex-1 py-3 px-4 rounded-xl bg-primary hover:bg-primary/90 text-white font-semibold text-sm transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer shadow-md"
							>
								<Save class="w-4 h-4" />
								<span id="save-btn-text">Save</span>
							</button>
						</div>
					</form>
				</div>
			</div>

		</div>

		<!-- Manage Categories Modal -->
		<!-- Manage Companies Modal -->
		<div id="companies-modal" class="hidden fixed inset-0 z-[80] flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
			<div class="bg-[#1D1B20] border border-[#2B2930] w-full max-w-md rounded-3xl p-6 space-y-6 shadow-2xl relative max-h-[90vh] flex flex-col justify-between">
				<div>
					<div class="border-b border-[#2B2930]/60 pb-3 flex justify-between items-center mb-4">
						<h3 class="text-lg font-bold text-white">Manage Companies</h3>
						<button id="close-companies-modal" class="text-[#E6E1E5]/60 hover:text-white transition-colors cursor-pointer text-xl font-bold">&times;</button>
					</div>

					<!-- Scrollable companies list with rearrange handles -->
					<div id="modal-companies-list" class="space-y-2 max-h-[300px] overflow-y-auto pr-1">
						<!-- Dynamically populated via JS -->
					</div>

					<!-- Add Company input -->
					<div class="mt-4 pt-4 border-t border-[#2B2930]/60 flex gap-2">
						<input
							type="text"
							id="new-company-input"
							placeholder="New company name..."
							class="flex-grow bg-[#141218] border border-[#2B2930] rounded-xl px-3.5 py-2 text-xs text-white focus:outline-none focus:border-primary transition-colors"
						/>
						<button
							type="button"
							id="btn-add-company"
							class="px-4 py-2 bg-primary hover:bg-primary/90 text-white font-semibold rounded-xl text-xs transition-all cursor-pointer"
						>
							Add
						</button>
					</div>
				</div>

				<div class="flex gap-3 mt-4 pt-4 border-t border-[#2B2930]/40">
					<button
						type="button"
						id="close-companies-modal-btn"
						class="flex-grow py-2.5 bg-transparent border border-[#2B2930] hover:bg-[#2B2930] text-[#E6E1E5]/60 hover:text-white font-semibold rounded-xl text-xs transition-all cursor-pointer text-center"
					>
						Cancel
					</button>
					<button
						type="button"
						id="btn-save-companies"
						class="flex-grow py-2.5 bg-primary hover:bg-primary/90 text-white font-semibold rounded-xl text-xs transition-all cursor-pointer flex items-center justify-center gap-2"
					>
						<Save class="w-3.5 h-3.5" />
						Save Changes
					</button>
				</div>
			</div>
		</div>

	</AdminLayout>
	<AdminNavDock currentPath={Astro.url.pathname} />

	<!-- Render Lightboxes outside transform scopes -->
	{designs.map(design => (
		<DesignLightbox design={design} />
	))}
</BackgroundBaseLayout>

<script define:vars={{ designs, initialCompanies: companies }}>
	// Make server-fetched items available to client script
	window.designs = designs || [];
	window.companies = initialCompanies || [];
</script>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Element Declarations
		const searchInput = document.getElementById('search-input') as HTMLInputElement;
		const btnNewDesign = document.getElementById('btn-new-design') as HTMLButtonElement;
		const designsGrid = document.getElementById('designs-grid') as HTMLDivElement;
		const loadMoreBtn = document.getElementById('btn-load-more') as HTMLButtonElement;
		const loadMoreContainer = document.getElementById('load-more-container') as HTMLDivElement;

		// Local State
		let ITEMS_PER_PAGE = 5;
		let displayedCount = 0;
		let allDesigns: any[] = (window as any).designs || [];

		// Filter Elements
		const btnFilterToggle = document.getElementById('btn-filter-toggle') as HTMLButtonElement;
		const filterBadge = document.getElementById('filter-badge') as HTMLSpanElement;
		const filterPanel = document.getElementById('filter-panel') as HTMLDivElement;
		const filterCompany = document.getElementById('filter-company') as HTMLSelectElement;
		const filterYear = document.getElementById('filter-year') as HTMLSelectElement;
		const filterStartDate = document.getElementById('filter-start-date') as HTMLInputElement;
		const filterEndDate = document.getElementById('filter-end-date') as HTMLInputElement;
		const btnClearFilters = document.getElementById('btn-clear-filters') as HTMLButtonElement;
		const btnCloseFilters = document.getElementById('btn-close-filters') as HTMLButtonElement;

		// Drawer Elements
		const editorPanel = document.getElementById('editor-panel') as HTMLDivElement;
		const editorBackdrop = document.getElementById('editor-backdrop') as HTMLDivElement;
		const btnCancel = document.getElementById('btn-cancel') as HTMLButtonElement;

		const editorHeading = document.getElementById('editor-heading') as HTMLHeadingElement;
		const editorSubheading = document.getElementById('editor-subheading') as HTMLParagraphElement;
		
		const designForm = document.getElementById('design-form') as HTMLFormElement;
		const formId = document.getElementById('form-id') as HTMLInputElement;
		const formTitle = document.getElementById('form-title') as HTMLInputElement;
		const formCompany = document.getElementById('form-company') as HTMLSelectElement;
		const formDate = document.getElementById('form-date') as HTMLInputElement;
		const formTags = document.getElementById('form-tags') as HTMLInputElement;

		const imageDropZone = document.getElementById('image-drop-zone') as HTMLDivElement;
		const imageFileInput = document.getElementById('image-file-input') as HTMLInputElement;
		const imagePreview = document.getElementById('image-preview') as HTMLImageElement;
		const dropZonePrompt = document.getElementById('drop-zone-prompt') as HTMLDivElement;
		const fileDetails = document.getElementById('file-details') as HTMLDivElement;

		const formStatus = document.getElementById('form-status') as HTMLDivElement;
		const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement;
		const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
		const saveBtnText = document.getElementById('save-btn-text') as HTMLSpanElement;

		// Companies Modal Elements
		const btnEditCompanies = document.getElementById('btn-edit-companies') as HTMLButtonElement;
		const companiesModal = document.getElementById('companies-modal') as HTMLDivElement;
		const closeCompaniesModal = document.getElementById('close-companies-modal') as HTMLButtonElement;
		const closeCompaniesModalBtn = document.getElementById('close-companies-modal-btn') as HTMLButtonElement;
		const modalCompaniesList = document.getElementById('modal-companies-list') as HTMLDivElement;
		const newCompanyInput = document.getElementById('new-company-input') as HTMLInputElement;
		const btnAddCompany = document.getElementById('btn-add-company') as HTMLButtonElement;
		const btnSaveCompanies = document.getElementById('btn-save-companies') as HTMLButtonElement;

		// Local State
		let selectedImageFile: File | null = null;
		let currentSelectedId: string | null = null;
		
		// Modal Working Drafts
		interface ModalItem {
			originalName: string;
			currentName: string;
		}
		let modalCompanies: ModalItem[] = [];

		// --- Core Setup & Initialization ---
		populateCompanyDropdown();
		renderDesigns();
		initFromUrl();

		function renderDesigns() {
			const newCards = allDesigns.slice(displayedCount, displayedCount + ITEMS_PER_PAGE);
			
			newCards.forEach(design => {
				const card = createDesignCard(design);
				designsGrid.appendChild(card);
			});
			
			displayedCount += newCards.length;
			
			if (displayedCount >= allDesigns.length) {
				loadMoreContainer.classList.add('hidden');
			} else {
				loadMoreContainer.classList.remove('hidden');
			}

			// Check if we need to show the "no designs" message
			if (displayedCount === 0 && allDesigns.length === 0) {
				const noDesignsDiv = document.createElement('div');
				noDesignsDiv.className = 'col-span-full py-16 text-center text-[#E6E1E5]/40 bg-[#1D1B20] rounded-3xl border border-[#2B2930]';
				noDesignsDiv.innerHTML = `
					<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 mx-auto mb-3 opacity-30 text-primary">
					  <circle cx="12" cy="12" r="10"></circle>
					  <path d="M8 12l2 2 4-4"></path>
					</svg>
					<p class="font-medium text-white">No designs found</p>
					<p class="text-xs mt-1">Click "New" to add your first mockup.</p>
				`;
				designsGrid.appendChild(noDesignsDiv);
			}
			
			// Re-attach event listeners to new cards
			attachCardEventListeners();
		}

		function createDesignCard(design: any) {
			const formattedDate = (() => {
				if (!design.date) return '';
				try {
					const parts = design.date.split('-');
					if (parts.length >= 2) {
						const year = parseInt(parts[0], 10);
						const month = parseInt(parts[1], 10) - 1;
						const d = new Date(year, month, 1);
						if (!isNaN(d.getTime())) {
							return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
						}
					}
					const d = new Date(design.date);
					if (!isNaN(d.getTime())) {
						return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
					}
				} catch (e) {}
				return design.date;
			})();

			const tagsHtml = design.tags && design.tags.length > 0 
				? `<div class="flex flex-wrap gap-1.5 mt-2">
						${design.tags.map((tag: string) => `
							<span class="text-[10px] text-primary/80 font-bold flex items-center gap-0.5 bg-[#2D2D2D] border border-white/5 px-2 py-0.5 rounded-md">
