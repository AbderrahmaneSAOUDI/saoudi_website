				modalCompaniesList.innerHTML = '<p class="text-xs text-[#E6E1E5]/50 text-center py-6">No companies. Create one below.</p>';
				return;
			}

			modalCompanies.forEach((comp, index) => {
				const designCount = allDesigns.filter((d: any) => d.company === comp.originalName).length;

				const row = document.createElement('div');
				row.className = 'flex items-center gap-2.5 bg-[#211F26] p-2.5 rounded-xl border border-[#2B2930]';
				
				row.innerHTML = `
					<div class="flex flex-col gap-1 shrink-0">
						<button 
							type="button" 
							class="btn-move-up-comp p-1 rounded hover:bg-[#141218] text-[#E6E1E5]/60 hover:text-primary transition-all disabled:opacity-20 cursor-pointer"
							data-index="${index}"
							${index === 0 ? 'disabled' : ''}
							title="Move Up"
						>
							<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
						</button>
						<button 
							type="button" 
							class="btn-move-down-comp p-1 rounded hover:bg-[#141218] text-[#E6E1E5]/60 hover:text-primary transition-all disabled:opacity-20 cursor-pointer"
							data-index="${index}"
							${index === modalCompanies.length - 1 ? 'disabled' : ''}
							title="Move Down"
						>
							<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
						</button>
					</div>
					<div class="flex-grow min-w-0">
						<input 
							type="text" 
							value="${comp.currentName}" 
							class="company-input-field w-full bg-[#141218] border border-[#2B2930] rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none focus:border-primary transition-colors font-medium"
							data-index="${index}"
						/>
						<span class="text-[9px] text-[#E6E1E5]/40 ml-1 mt-0.5 block">${designCount} associated designs</span>
					</div>
					<button 
						type="button" 
						class="btn-delete-comp p-2 rounded-lg bg-[#DB4437]/10 border border-[#DB4437]/20 hover:bg-[#DB4437] text-[#DB4437] hover:text-white transition-all shrink-0 cursor-pointer"
						data-index="${index}"
						title="Delete Company"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
					</button>
				`;

				modalCompaniesList.appendChild(row);
			});

			modalCompaniesList.querySelectorAll('.btn-move-up-comp').forEach(btn => {
				btn.addEventListener('click', () => {
					const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
					moveCompanyItem(idx, -1);
				});
			});

			modalCompaniesList.querySelectorAll('.btn-move-down-comp').forEach(btn => {
				btn.addEventListener('click', () => {
					const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
					moveCompanyItem(idx, 1);
				});
			});

			modalCompaniesList.querySelectorAll('.btn-delete-comp').forEach(btn => {
				btn.addEventListener('click', () => {
					const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
					const item = modalCompanies[idx];
					if (item.originalName) {
						const count = ((window as any).designs || []).filter((d: any) => d.company === item.originalName).length;
						if (count > 0) {
							const confirmDelete = confirm(`Warning: "${item.originalName}" is associated with ${count} designs. Do you still want to delete it?`);
							if (!confirmDelete) return;
						}
					}
					modalCompanies.splice(idx, 1);
					renderModalCompanies();
				});
			});

			modalCompaniesList.querySelectorAll('.company-input-field').forEach(input => {
				input.addEventListener('input', (e) => {
					const idx = parseInt(input.getAttribute('data-index') || '0', 10);
					modalCompanies[idx].currentName = (e.target as HTMLInputElement).value;
				});
			});
		}

		function moveCompanyItem(index: number, shift: number) {
			const targetIndex = index + shift;
			if (targetIndex < 0 || targetIndex >= modalCompanies.length) return;
			
			const temp = modalCompanies[index];
			modalCompanies[index] = modalCompanies[targetIndex];
			modalCompanies[targetIndex] = temp;
			renderModalCompanies();
		}

		btnEditCompanies.addEventListener('click', () => {
			const currentComps = (window as any).companies || [];
			modalCompanies = currentComps.map((name: string) => ({
				originalName: name,
				currentName: name
			}));
			companiesModal.classList.remove('hidden');
			renderModalCompanies();
		});

		closeCompaniesModal.addEventListener('click', () => {
			companiesModal.classList.add('hidden');
		});

		if (closeCompaniesModalBtn) {
			closeCompaniesModalBtn.addEventListener('click', () => {
				companiesModal.classList.add('hidden');
			});
		}

		// Add Company
		btnAddCompany.addEventListener('click', () => {
			const newName = newCompanyInput.value.trim();
			if (!newName) return;
			
			if (modalCompanies.some(c => c.currentName.toLowerCase() === newName.toLowerCase())) {
				alert('Company already exists!');
				return;
			}

			modalCompanies.push({ originalName: '', currentName: newName });
			newCompanyInput.value = '';
			renderModalCompanies();
		});

		// Save Companies Changes
		btnSaveCompanies.addEventListener('click', async () => {
			const cleanComps = modalCompanies.map(c => ({
				originalName: c.originalName,
				currentName: c.currentName.trim()
			})).filter(c => c.currentName !== '');

			btnSaveCompanies.disabled = true;
			btnSaveCompanies.textContent = 'Saving...';

			const companiesList = cleanComps.map(c => c.currentName);
			const renames: Record<string, string> = {};
			
			cleanComps.forEach(c => {
				if (c.originalName && c.originalName !== c.currentName) {
					renames[c.originalName] = c.currentName;
				}
			});

			try {
				const formData = new FormData();
				formData.append('action', 'save_companies');
				formData.append('companies', JSON.stringify(companiesList));
				formData.append('renames', JSON.stringify(renames));

				const res = await fetch('/admin/admin_designs_api', {
					method: 'POST',
					body: formData
				});
				const data = await res.json();

				if (res.ok && data.success) {
					(window as any).companies = companiesList;
					
					Object.keys(renames).forEach(oldComp => {
						const newComp = renames[oldComp];
						allDesigns.forEach((d: any) => {
							if (d.company === oldComp) d.company = newComp;
						});
					});

					// Update DOM cards displaying company names
					document.querySelectorAll('.design-card').forEach(card => {
						const cardId = card.getAttribute('data-id');
						const design = allDesigns.find((d: any) => d && d.id === cardId);
						if (design) {
							// Update company pill if it exists or delete it
							const footer = card.querySelector('.design-card-footer');
							if (footer) {
								let companySpan = footer.querySelector('.company-pill') as HTMLElement | undefined;
								if (design.company) {
									if (!companySpan) {
										companySpan = document.createElement('span');
										companySpan.className = 'company-pill px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase bg-primary/10 border border-primary/20 text-primary';
										footer.appendChild(companySpan);
									}
									companySpan.textContent = design.company;
								} else if (companySpan) {
									companySpan.remove();
								}
							}
						}
					});

					populateCompanyDropdown();
					companiesModal.classList.add('hidden');
					alert('Companies updated successfully!');
				} else {
					alert(data.error || 'Failed to save companies.');
				}
			} catch (err: any) {
				alert('Error saving companies: ' + (err?.message || err));
			} finally {
				btnSaveCompanies.disabled = false;
				btnSaveCompanies.textContent = 'Save Changes';
			}
		});

		// --- Search & Filter Logic ---
		function applyFilters() {
			const query = searchInput.value.toLowerCase().trim();
			const selectedCompany = filterCompany.value;
			const selectedYear = filterYear.value;
			const startDateVal = filterStartDate.value;
			const endDateVal = filterEndDate.value;

			let activeFiltersCount = 0;
			if (selectedCompany) activeFiltersCount++;
			if (selectedYear) activeFiltersCount++;
			if (startDateVal) activeFiltersCount++;
			if (endDateVal) activeFiltersCount++;

			// Update badge and clear button state
			if (activeFiltersCount > 0) {
				filterBadge.textContent = String(activeFiltersCount);
				filterBadge.classList.remove('hidden');
				btnClearFilters.classList.remove('opacity-50', 'cursor-not-allowed');
				btnClearFilters.disabled = false;
				btnFilterToggle.classList.add('border-primary', 'bg-primary/5');
			} else {
				filterBadge.classList.add('hidden');
				btnClearFilters.classList.add('opacity-50', 'cursor-not-allowed');
				btnClearFilters.disabled = true;
				btnFilterToggle.classList.remove('border-primary', 'bg-primary/5');
			}

			// Parse date limits if provided
			const startDate = startDateVal ? new Date(startDateVal) : null;
			const endDate = endDateVal ? new Date(endDateVal) : null;

			const designCards = designsGrid.querySelectorAll('.design-card') as NodeListOf<HTMLDivElement>;
			designCards.forEach(card => {
				const cardId = card.getAttribute('data-id') || '';
				const design = allDesigns.find((d: any) => d.id === cardId);
				if (!design) return;

				const title = (design.title || '').toLowerCase();
				const company = (design.company || '');
				const tags = (Array.isArray(design.tags) ? design.tags.join(' ') : '').toLowerCase();

				const matchesSearch = !query || 
					title.includes(query) || 
					company.toLowerCase().includes(query) || 
					tags.includes(query);

				let matchesCompany = true;
				if (selectedCompany !== '') {
					matchesCompany = design.company === selectedCompany;
				}

				let matchesYear = true;
				if (selectedYear !== '') {
					if (typeof design.date === 'string' && design.date.includes('-')) {
						const year = design.date.split('-')[0];
						matchesYear = year === selectedYear;
					} else {
						matchesYear = false;
					}
				}

				let matchesDateInterval = true;
				if (design.date) {
					const designDate = new Date(design.date);
					if (startDate && designDate < startDate) {
						matchesDateInterval = false;
					}
					if (endDate && designDate > endDate) {
						matchesDateInterval = false;
					}
				} else if (startDate || endDate) {
					matchesDateInterval = false;
				}

				if (matchesSearch && matchesCompany && matchesYear && matchesDateInterval) {
					card.classList.remove('hidden');
				} else {
					card.classList.add('hidden');
				}
			});
		}

		// Filter Toggle Panel
		btnFilterToggle.addEventListener('click', () => {
			openFilterDrawer();
		});

		// Clear Filters
		btnClearFilters.addEventListener('click', () => {
			filterCompany.value = '';
			filterYear.value = '';
			filterStartDate.value = '';
			filterEndDate.value = '';
			applyFilters();
		});

		// Event Listeners for Filters
		filterCompany.addEventListener('change', applyFilters);
		filterYear.addEventListener('change', applyFilters);
		filterStartDate.addEventListener('change', applyFilters);
		filterEndDate.addEventListener('change', applyFilters);
		searchInput.addEventListener('input', applyFilters);

		btnNewDesign.addEventListener('click', () => {
			setNewDesignState();
			openDrawer();
		});

		// --- Image Drop Zone Controls ---
		imageDropZone.addEventListener('click', () => imageFileInput.click());

		imageFileInput.addEventListener('change', () => {
			const file = imageFileInput.files?.[0];
			if (file) handleFileSelection(file);
		});

		imageDropZone.addEventListener('dragover', (e) => {
			e.preventDefault();
			imageDropZone.classList.add('border-primary', 'bg-primary/5');
		});

		imageDropZone.addEventListener('dragleave', () => {
			imageDropZone.classList.remove('border-primary', 'bg-primary/5');
		});

		imageDropZone.addEventListener('drop', (e) => {
			e.preventDefault();
			imageDropZone.classList.remove('border-primary', 'bg-primary/5');
			const file = e.dataTransfer?.files?.[0];
			if (file) handleFileSelection(file);
		});

		function processAndCompressImage(file: File): Promise<File> {
			return new Promise((resolve, reject) => {
				const img = new Image();
				img.src = URL.createObjectURL(file);
				
				img.onload = () => {
					URL.revokeObjectURL(img.src);

					const maxDim = 1024;
					let width = img.width;
					let height = img.height;
					const needsResize = width > maxDim || height > maxDim;

					if (needsResize) {
						if (width > height) {
							height = Math.round((height * maxDim) / width);
							width = maxDim;
						} else {
							width = Math.round((width * maxDim) / height);
							height = maxDim;
						}
					}

					const canvas = document.createElement('canvas');
					canvas.width = width;
					canvas.height = height;
					const ctx = canvas.getContext('2d');
					if (!ctx) {
						resolve(file);
						return;
					}

					ctx.drawImage(img, 0, 0, width, height);

					canvas.toBlob((blob) => {
						if (blob) {
							const baseName = file.name.substring(0, file.name.lastIndexOf('.')) || file.name;
							const newFile = new File([blob], `${baseName}.webp`, {
								type: 'image/webp',
								lastModified: Date.now()
							});
							resolve(newFile);
						} else {
							resolve(file);
						}
					}, 'image/webp', 0.8);
				};

				img.onerror = () => {
					reject(new Error('Failed to load image file for processing.'));
				};
			});
		}

		async function handleFileSelection(file: File) {
			const allowedTypes = ['image/jpeg', 'image/png', 'image/webp'];
			if (!allowedTypes.includes(file.type)) {
				showStatus('error', 'Only JPEG, PNG, or WebP files are allowed.');
				return;
			}
			if (file.size > 10 * 1024 * 1024) {
				showStatus('error', 'Image size must be under 10MB.');
				return;
			}

			showStatus('success', 'Optimizing and converting image to WebP...');

			try {
				const processedFile = await processAndCompressImage(file);
				if (processedFile.size > 800 * 1024) {
					showStatus('error', `Optimized image is too large (${(processedFile.size / 1024).toFixed(0)}KB). Please upload a smaller or less complex image.`);
					selectedImageFile = null;
					return;
				}
				selectedImageFile = processedFile;
				clearStatus();

				// Generate locally readable preview URL
				const reader = new FileReader();
				reader.onload = (e) => {
					if (e.target?.result) {
						imagePreview.src = e.target.result as string;
						imagePreview.classList.remove('hidden');
						dropZonePrompt.classList.add('hidden');
						fileDetails.classList.remove('hidden');
						
						const originalSize = (file.size / 1024 / 1024).toFixed(2);
						const processedSize = (processedFile.size / 1024 / 1024).toFixed(2);
						fileDetails.textContent = `✓ ${processedFile.name} (${processedSize} MB, was ${originalSize} MB)`;
					}
				};
				reader.readAsDataURL(processedFile);
			} catch (err: any) {
				showStatus('error', err.message || 'Failed to process image.');
			}
		}

		// --- CRUD Network Handlers ---
		
		// SAVE (Create or Update)
		designForm.addEventListener('submit', async (e) => {
			e.preventDefault();

			// Image validation for new creation
			if (!currentSelectedId && !selectedImageFile) {
				showStatus('error', 'Please upload a mockup image for the new design.');
				return;
			}

			// Lock buttons
			setFormLoading(true, 'Saving...');

			const formData = new FormData();
			formData.append('action', 'save');
			formData.append('id', formId.value);
			formData.append('title', formTitle.value);
			formData.append('company', formCompany.value);
			formData.append('date', formDate.value);
			formData.append('tags', formTags.value);

			if (selectedImageFile) {
				formData.append('image', selectedImageFile);
			}

			try {
				const response = await fetch('/admin/admin_designs_api', {
					method: 'POST',
					body: formData
				});
				const result = await response.json();

				if (response.ok && result.success) {
					showStatus('success', 'Design saved successfully! Refreshing...');
					setTimeout(() => {
						window.location.href = window.location.pathname;
					}, 1000);
				} else {
					showStatus('error', result.error || 'Failed to save design.');
					setFormLoading(false);
				}
			} catch (err) {
				showStatus('error', 'A network error occurred. Please try again.');
				setFormLoading(false);
			}
		});

		// DELETE
		btnDelete.addEventListener('click', async () => {
			if (!currentSelectedId) return;

			const confirmed = confirm('Are you sure you want to delete this design project? This action will permanently remove the record and its cover image.');
			if (!confirmed) return;

			setFormLoading(true, 'Deleting...');

			const formData = new FormData();
			formData.append('action', 'delete');
			formData.append('id', currentSelectedId);

			try {
				const response = await fetch('/admin/admin_designs_api', {
					method: 'POST',
					body: formData
				});
				const result = await response.json();

				if (response.ok && result.success) {
					showStatus('success', 'Design deleted successfully! Syncing...');
					setTimeout(() => {
						window.location.href = window.location.pathname;
					}, 1000);
				} else {
					showStatus('error', result.error || 'Failed to delete design.');
					setFormLoading(false);
				}
			} catch (err) {
				showStatus('error', 'A network error occurred. Please try again.');
				setFormLoading(false);
			}
		});

		// --- Helper Utilities ---
		function showStatus(type: 'success' | 'error', message: string) {
			formStatus.classList.remove('hidden', 'bg-[#0F9D58]/10', 'text-[#0F9D58]', 'border-[#0F9D58]/30', 'bg-[#DB4437]/10', 'text-[#DB4437]', 'border-[#DB4437]/30');
			
			if (type === 'success') {
				formStatus.classList.add('bg-[#0F9D58]/10', 'text-[#0F9D58]', 'border', 'border-[#0F9D58]/30');
			} else {
				formStatus.classList.add('bg-[#DB4437]/10', 'text-[#DB4437]', 'border', 'border-[#DB4437]/30');
			}
			
			formStatus.textContent = message;
			formStatus.classList.remove('hidden');
		}

		function clearStatus() {
			formStatus.classList.add('hidden');
			formStatus.textContent = '';
		}

		function setFormLoading(loading: boolean, label = 'Save') {
			if (loading) {
				btnSave.disabled = true;
				btnCancel.disabled = true;
				btnDelete.disabled = true;
				saveBtnText.textContent = label;
				btnSave.classList.add('opacity-75', 'cursor-not-allowed');
			} else {
				btnSave.disabled = false;
				btnCancel.disabled = false;
				btnDelete.disabled = false;
				saveBtnText.textContent = 'Save';
				btnSave.classList.remove('opacity-75', 'cursor-not-allowed');
			}
		}
	});
</script>