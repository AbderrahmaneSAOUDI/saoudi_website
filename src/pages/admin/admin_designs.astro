		function attachCardEventListeners() {
			const designCards = designsGrid.querySelectorAll('.design-card') as NodeListOf<HTMLDivElement>;
			designCards.forEach(card => {
				card.addEventListener('click', (e) => {
					// If clicking the image link, let the CSS lightbox handle it and stop propagation
					if ((e.target as HTMLElement).closest('.image-zoom-trigger')) {
						return;
					}
					const id = card.getAttribute('data-id');
					const design = allDesigns.find((d: any) => d.id === id);
					if (design) {
						// Set URL query param
						const newUrl = new URL(window.location.href);
						newUrl.searchParams.set('id', design.id);
						window.history.pushState(null, '', newUrl.toString());
						
						selectDesign(design);
						openDrawer();
					}
				});
			});
		}

		loadMoreBtn.addEventListener('click', () => {
			ITEMS_PER_PAGE = allDesigns.length;
			renderDesigns();
		});

		// Handle URL state initialization
		function initFromUrl() {
			const urlParams = new URLSearchParams(window.location.search);
			const urlId = urlParams.get('id');

			if (urlId) {
				const design = allDesigns.find((d: any) => d.id === urlId);
				if (design) {
					selectDesign(design);
					openDrawer();
					return;
				}
			}
		}

		// --- Drawer Controls ---
		function openDrawer() {
			editorBackdrop.classList.remove('hidden');
			// Allow reflow for transition
			setTimeout(() => {
				editorBackdrop.classList.add('opacity-100');
				editorPanel.classList.remove('translate-x-full');
				editorPanel.classList.add('translate-x-0');
			}, 10);
		}

		function closeDrawer() {
			editorBackdrop.classList.remove('opacity-100');
			editorPanel.classList.remove('translate-x-0');
			editorPanel.classList.add('translate-x-full');

			// Clean query params on close
			const newUrl = new URL(window.location.href);
			newUrl.searchParams.delete('id');
			window.history.pushState(null, '', newUrl.toString());

			// Highlights cards off
			const designCards = designsGrid.querySelectorAll('.design-card') as NodeListOf<HTMLDivElement>;
			designCards.forEach(c => c.classList.remove('ring-2', 'ring-primary/60', 'border-primary/50'));

			setTimeout(() => {
				editorBackdrop.classList.add('hidden');
			}, 350);
		}

		function openFilterDrawer() {
			editorBackdrop.classList.remove('hidden');
			// Allow reflow for transition
			setTimeout(() => {
				editorBackdrop.classList.add('opacity-100');
				filterPanel.classList.remove('-translate-x-full');
				filterPanel.classList.add('translate-x-0');
			}, 10);
		}

		function closeFilterDrawer() {
			editorBackdrop.classList.remove('opacity-100');
			filterPanel.classList.remove('translate-x-0');
			filterPanel.classList.add('-translate-x-full');

			setTimeout(() => {
				editorBackdrop.classList.add('hidden');
			}, 350);
		}

		btnCancel.addEventListener('click', closeDrawer);
		if (btnCloseFilters) {
			btnCloseFilters.addEventListener('click', closeFilterDrawer);
		}
		editorBackdrop.addEventListener('click', () => {
			closeDrawer();
			closeFilterDrawer();
		});

		// --- Form State Management ---
		function setNewDesignState() {
			currentSelectedId = null;
			
			// Generate short safe random UUID/ID
			const shortId = (crypto && crypto.randomUUID) 
				? crypto.randomUUID().substring(0, 8) 
				: Math.random().toString(36).substring(2, 10);
			
			formId.value = `design_${shortId}`;
			formTitle.value = '';

			// Default company selection
			const comps = (window as any).companies || [];
			formCompany.value = comps.length > 0 ? comps[0] : '';
			
			// Set today's date formatted as YYYY-MM-DD
			const today = new Date().toISOString().split('T')[0];
			formDate.value = today;
			formTags.value = '';

			// Reset image preview state
			selectedImageFile = null;
			imageFileInput.value = '';
			imagePreview.classList.add('hidden');
			imagePreview.src = '';
			dropZonePrompt.classList.remove('hidden');
			fileDetails.classList.add('hidden');

			// Adjust UI panel headers and buttons
			editorHeading.textContent = 'Create Design';
			editorSubheading.textContent = 'Add a new portfolio entry';
			btnDelete.classList.add('hidden');
			
			// Clear status alert
			clearStatus();
		}

		function selectDesign(design: any) {
			currentSelectedId = design.id;

			formId.value = design.id;
			formTitle.value = design.title || '';
			formCompany.value = design.company || '';
			formDate.value = design.date ? design.date.split('T')[0] : '';
			formTags.value = Array.isArray(design.tags) ? design.tags.join(', ') : '';

			// Setup preview image
			selectedImageFile = null;
			imageFileInput.value = '';
			if (design.imageUrl) {
				imagePreview.src = design.imageUrl;
				imagePreview.classList.remove('hidden');
				dropZonePrompt.classList.add('hidden');
				fileDetails.classList.add('hidden');
			} else {
				imagePreview.classList.add('hidden');
				imagePreview.src = '';
				dropZonePrompt.classList.remove('hidden');
				fileDetails.classList.add('hidden');
			}

			// Highlights active design card in list
			const designCards = designsGrid.querySelectorAll('.design-card') as NodeListOf<HTMLDivElement>;
			designCards.forEach(c => {
				if (c.getAttribute('data-id') === design.id) {
					c.classList.add('ring-2', 'ring-primary/60', 'border-primary/50');
				} else {
					c.classList.remove('ring-2', 'ring-primary/60', 'border-primary/50');
				}
			});

			editorHeading.textContent = 'Edit Design';
			editorSubheading.textContent = 'Modify your mockup credentials';
			btnDelete.classList.remove('hidden');

			clearStatus();
		}

		// --- Populating selects dropdowns ---
		
		// --- Populating selects dropdowns ---
		
		function populateCompanyDropdown(selectedValue = '') {
			const activeValue = selectedValue || formCompany.value;
			formCompany.innerHTML = '';

			const filterActiveValue = filterCompany ? filterCompany.value : '';
			if (filterCompany) {
				filterCompany.innerHTML = `
					<option value="">All Companies</option>
				`;
			}
			
			const companies = (window as any).companies || [];
			companies.forEach((comp: string) => {
				const opt = document.createElement('option');
				opt.value = comp;
				opt.textContent = comp;
				formCompany.appendChild(opt);

				if (filterCompany) {
					const filterOpt = document.createElement('option');
					filterOpt.value = comp;
					filterOpt.textContent = comp;
					filterCompany.appendChild(filterOpt);
				}
			});

			if (companies.includes(activeValue)) {
				formCompany.value = activeValue;
			} else if (companies.length > 0) {
				formCompany.value = companies[0];
			}
			if (filterCompany && companies.includes(filterActiveValue)) {
				filterCompany.value = filterActiveValue;
			}
		}

		// --- Companies management modal logic ---

