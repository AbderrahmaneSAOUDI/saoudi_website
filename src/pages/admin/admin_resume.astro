---
import '../../styles/global.css';

import BackgroundBaseLayout from "../../layouts/BackgroundBaseLayout.astro";
import AdminLayout from "../../components/admin/AdminLayout.astro";
import AdminNavDock from "../../components/admin/AdminNavDock.astro";
import { getFirebaseAdminDb } from "../../lib/server/firebase-admin";
import { FileText, Upload, Image, Download, ExternalLink, CheckCircle, AlertCircle } from '@lucide/astro';

// Extra safety: double-check that the middleware successfully set Astro.locals.adminEmail
const adminEmail = Astro.locals.adminEmail;
if (!adminEmail) return Astro.redirect("/admin/admin_login");

// Fetch current resume data from Firestore configuration
let currentResumeUrl = '/Abderrahmane_SAOUDI_Resume.pdf';
let currentPreviewUrl = '/resume.jpg';
let firestoreStatus = 'connected';

try {
	const db = getFirebaseAdminDb();
	const configDoc = await db.collection('configuration').doc('static_data').get();

	if (configDoc.exists) {
		const data = configDoc.data();
		if (data?.resumeUrl) currentResumeUrl = data.resumeUrl;
	}
} catch (error) {
	console.warn('Failed to fetch resume config from Firestore:', error);
	firestoreStatus = 'degraded';
}
---

<BackgroundBaseLayout title="Resume Workspace">
	<AdminLayout title="Resume">

		<!-- Main Content: Two Column Layout -->
		<div class="flex flex-col lg:flex-row gap-6">

			<!-- Left Column: Upload Controls (33%) -->
			<div class="w-full lg:w-1/3 space-y-6">

				<!-- Upload Resume PDF Card -->
				<div class="p-6 rounded-3xl border border-[#2B2930]" style="background: #1D1B20">
					<div class="flex items-center gap-3 mb-5">
						<div class="p-2.5 rounded-xl bg-[#0F9D58]/10 text-[#0F9D58]">
							<Upload class="w-5 h-5" />
						</div>
						<div>
							<h3 class="text-base font-bold text-white">Upload New PDF</h3>
							<p class="text-xs text-[#E6E1E5]/50">Replace the current resume file</p>
						</div>
					</div>

					<!-- Drop Zone for PDF -->
					<div
						id="pdf-drop-zone"
						class="border-2 border-dashed border-[#2B2930] hover:border-[#4285F4]/50 rounded-2xl p-6 text-center transition-all duration-300 cursor-pointer group"
					>
						<input
							type="file"
							id="pdf-file-input"
							accept=".pdf,application/pdf"
							class="hidden"
						/>
						<div class="flex flex-col items-center gap-3">
							<div class="p-3 rounded-full bg-[#4285F4]/10 text-[#4285F4] group-hover:bg-[#4285F4]/20 transition-colors">
								<FileText class="w-6 h-6" />
							</div>
							<div>
								<p class="text-sm font-medium text-white">
									Drop PDF here or <span class="text-[#4285F4]">browse</span>
								</p>
								<p class="text-xs text-[#E6E1E5]/40 mt-1">PDF only, max 10MB</p>
							</div>
						</div>
						<!-- Selected file name -->
						<div id="pdf-file-name" class="hidden mt-3 px-3 py-1.5 rounded-xl bg-[#0F9D58]/10 text-[#0F9D58] text-xs font-medium"></div>
					</div>
				</div>

				<!-- Upload Preview Image Card -->
				<div class="p-6 rounded-3xl border border-[#2B2930]" style="background: #1D1B20">
					<div class="flex items-center gap-3 mb-5">
						<div class="p-2.5 rounded-xl bg-[#F9AB00]/10 text-[#F9AB00]">
							<Image class="w-5 h-5" />
						</div>
						<div>
							<h3 class="text-base font-bold text-white">Upload Preview Image</h3>
							<p class="text-xs text-[#E6E1E5]/50">Screenshot of the resume for display</p>
						</div>
					</div>

					<!-- Drop Zone for Image -->
					<div
						id="preview-drop-zone"
						class="border-2 border-dashed border-[#2B2930] hover:border-[#F9AB00]/50 rounded-2xl p-6 text-center transition-all duration-300 cursor-pointer group"
					>
						<input
							type="file"
							id="preview-file-input"
							accept="image/jpeg,image/png,image/webp"
							class="hidden"
						/>
						<div class="flex flex-col items-center gap-3">
							<div class="p-3 rounded-full bg-[#F9AB00]/10 text-[#F9AB00] group-hover:bg-[#F9AB00]/20 transition-colors">
								<Image class="w-6 h-6" />
							</div>
							<div>
								<p class="text-sm font-medium text-white">
									Drop image here or <span class="text-[#F9AB00]">browse</span>
								</p>
								<p class="text-xs text-[#E6E1E5]/40 mt-1">JPEG, PNG, or WebP, max 10MB</p>
							</div>
						</div>
						<!-- Selected file name -->
						<div id="preview-file-name" class="hidden mt-3 px-3 py-1.5 rounded-xl bg-[#F9AB00]/10 text-[#F9AB00] text-xs font-medium"></div>
					</div>
				</div>

				<!-- Upload Button -->
				<button
					id="upload-btn"
					disabled
					class="w-full py-3 px-6 rounded-xl font-semibold text-white transition-all duration-300 bg-[#0F9D58] hover:bg-[#0F9D58]/90 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-[#0F9D58] flex items-center justify-center gap-2"
				>
					<Upload class="w-4 h-4" />
					<span id="upload-btn-text">Upload Selected Files</span>
				</button>

				<!-- Status Messages -->
				<div id="upload-status" class="hidden p-4 rounded-2xl text-sm font-medium animate-fade-in border"></div>

			</div>

			<!-- Right Column: Current Resume Preview (66%) -->
			<div class="w-full lg:w-2/3 space-y-6">

				<!-- Resume Preview Card -->
				<div class="p-6 rounded-3xl border border-[#2B2930] h-full flex flex-col" style="background: #1D1B20">
					<div class="flex items-center justify-between mb-5 shrink-0">
						<div class="flex items-center gap-3">
							<div class="p-2.5 rounded-xl bg-[#4285F4]/10 text-[#4285F4]">
								<FileText class="w-5 h-5" />
							</div>
							<div>
								<h2 class="text-lg font-bold text-white">Current Resume</h2>
								<p class="text-xs text-[#E6E1E5]/50">Preview of the active resume file</p>
							</div>
						</div>
						<a
							href={currentResumeUrl}
							download
							class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 border border-[#4285F4]/40 text-[#4285F4] hover:bg-[#4285F4] hover:text-white"
						>
							<Download class="w-4 h-4" />
							<span class="hidden sm:inline">Download PDF</span>
						</a>
					</div>

					<!-- Preview Image -->
					<div class="border border-[#2B2930] rounded-2xl overflow-hidden bg-[#141218] flex-1 flex items-center justify-center min-h-[300px]">
						<img
							id="resume-preview-img"
							src={currentPreviewUrl}
							alt="Resume preview"
							class="w-full object-contain max-h-[70vh]"
						/>
					</div>
				</div>
			</div>
		</div>

	</AdminLayout>
	<AdminNavDock currentPath={Astro.url.pathname} />
</BackgroundBaseLayout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const pdfDropZone = document.getElementById('pdf-drop-zone') as HTMLDivElement;
		const pdfFileInput = document.getElementById('pdf-file-input') as HTMLInputElement;
		const pdfFileName = document.getElementById('pdf-file-name') as HTMLDivElement;

		const previewDropZone = document.getElementById('preview-drop-zone') as HTMLDivElement;
		const previewFileInput = document.getElementById('preview-file-input') as HTMLInputElement;
		const previewFileName = document.getElementById('preview-file-name') as HTMLDivElement;

		const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
		const uploadBtnText = document.getElementById('upload-btn-text') as HTMLSpanElement;
		const uploadStatus = document.getElementById('upload-status') as HTMLDivElement;
		const previewImg = document.getElementById('resume-preview-img') as HTMLImageElement;

		let selectedPdf: File | null = null;
		let selectedPreview: File | null = null;

		// --- Drop Zone Helpers ---

		function setupDropZone(
			dropZone: HTMLDivElement,
			fileInput: HTMLInputElement,
			fileNameEl: HTMLDivElement,
			acceptTypes: string[],
			onFileSelected: (file: File) => void
		) {
			// Click to browse
			dropZone.addEventListener('click', () => fileInput.click());

			// File input change
			fileInput.addEventListener('change', () => {
				const file = fileInput.files?.[0];
				if (file && acceptTypes.some(t => file.type === t || file.name.endsWith(t))) {
					onFileSelected(file);
				}
			});

			// Drag & drop
			dropZone.addEventListener('dragover', (e) => {
				e.preventDefault();
				dropZone.classList.add('border-[#4285F4]', 'bg-[#4285F4]/5');
			});

			dropZone.addEventListener('dragleave', () => {
				dropZone.classList.remove('border-[#4285F4]', 'bg-[#4285F4]/5');
			});

			dropZone.addEventListener('drop', (e) => {
				e.preventDefault();
				dropZone.classList.remove('border-[#4285F4]', 'bg-[#4285F4]/5');
				const file = e.dataTransfer?.files[0];
				if (file && acceptTypes.some(t => file.type === t || file.name.endsWith(t))) {
					onFileSelected(file);
				}
			});
		}

		function showFileName(el: HTMLDivElement, name: string, size: number) {
			const sizeMB = (size / (1024 * 1024)).toFixed(2);
			el.textContent = `✓ ${name} (${sizeMB} MB)`;
			el.classList.remove('hidden');
		}

		function updateUploadButton() {
			uploadBtn.disabled = !selectedPdf && !selectedPreview;
		}

		// --- Setup PDF Drop Zone ---
		setupDropZone(
			pdfDropZone,
			pdfFileInput,
			pdfFileName,
			['application/pdf', '.pdf'],
			(file) => {
				selectedPdf = file;
				showFileName(pdfFileName, file.name, file.size);
				updateUploadButton();
			}
		);

		// --- Setup Preview Image Drop Zone ---
		setupDropZone(
			previewDropZone,
			previewFileInput,
			previewFileName,
			['image/jpeg', 'image/png', 'image/webp'],
			(file) => {
				selectedPreview = file;
				showFileName(previewFileName, file.name, file.size);
				updateUploadButton();

				// Live preview
				const reader = new FileReader();
				reader.onload = (e) => {
					if (previewImg && e.target?.result) {
						previewImg.src = e.target.result as string;
					}
				};
				reader.readAsDataURL(file);
			}
		);

		// --- Upload Handler ---
		uploadBtn.addEventListener('click', async () => {
			if (!selectedPdf && !selectedPreview) return;

			// Disable button, show loading
			uploadBtn.disabled = true;
			uploadBtnText.textContent = 'Uploading...';
			uploadStatus.classList.add('hidden');

			const formData = new FormData();
			if (selectedPdf) formData.append('resumePdf', selectedPdf);
			if (selectedPreview) formData.append('resumePreview', selectedPreview);

			try {
				const response = await fetch('/admin/admin_resume_upload', {
					method: 'POST',
					body: formData,
				});

				const result = await response.json();

				if (response.ok && result.success) {
					showStatus('success', 'Resume updated successfully! Changes will appear on the public page.');

					// Reset selections
					selectedPdf = null;
					selectedPreview = null;
					pdfFileName.classList.add('hidden');
					previewFileName.classList.add('hidden');
					pdfFileInput.value = '';
					previewFileInput.value = '';
				} else {
					showStatus('error', result.error || 'Upload failed. Please try again.');
				}
			} catch (err) {
				showStatus('error', 'Network error. Please check your connection and try again.');
			}

			uploadBtnText.textContent = 'Upload Selected Files';
			updateUploadButton();
		});

		function showStatus(type: 'success' | 'error', message: string) {
			uploadStatus.classList.remove('hidden', 'bg-[#0F9D58]/10', 'text-[#0F9D58]', 'border-[#0F9D58]/30', 'bg-[#DB4437]/10', 'text-[#DB4437]', 'border-[#DB4437]/30');

			if (type === 'success') {
				uploadStatus.classList.add('bg-[#0F9D58]/10', 'text-[#0F9D58]', 'border', 'border-[#0F9D58]/30');
			} else {
				uploadStatus.classList.add('bg-[#DB4437]/10', 'text-[#DB4437]', 'border', 'border-[#DB4437]/30');
			}

			uploadStatus.textContent = message;
		}
	});
</script>