---
let appResult = '';
let firestoreResult = '';
let authResult = '';
let storageResult = '';
let localEnvResult = '';
let localFirebaseResult = '';

try {
  await import('firebase-admin/app');
  appResult = 'SUCCESS';
} catch (e: any) {
  appResult = `FAILURE: ${e.message}\n${e.stack || ''}`;
}

try {
  await import('firebase-admin/firestore');
  firestoreResult = 'SUCCESS';
} catch (e: any) {
  firestoreResult = `FAILURE: ${e.message}\n${e.stack || ''}`;
}

try {
  await import('firebase-admin/auth');
  authResult = 'SUCCESS';
} catch (e: any) {
  authResult = `FAILURE: ${e.message}\n${e.stack || ''}`;
}

try {
  await import('firebase-admin/storage');
  storageResult = 'SUCCESS';
} catch (e: any) {
  storageResult = `FAILURE: ${e.message}\n${e.stack || ''}`;
}

try {
  await import('../lib/server/env');
  localEnvResult = 'SUCCESS';
} catch (e: any) {
  localEnvResult = `FAILURE: ${e.message}\n${e.stack || ''}`;
}

try {
  await import('../lib/server/firebase-admin');
  localFirebaseResult = 'SUCCESS';
} catch (e: any) {
  localFirebaseResult = `FAILURE: ${e.message}\n${e.stack || ''}`;
}
---
<!DOCTYPE html>
<html>
<head>
  <title>Debug Import All</title>
</head>
<body style="background: #121212; color: #fff; font-family: monospace; padding: 20px;">
  <h1>Detailed Import Debug</h1>
  
  <p><strong>firebase-admin/app:</strong> {appResult}</p>
  <p><strong>firebase-admin/firestore:</strong> {firestoreResult}</p>
  <p><strong>firebase-admin/auth:</strong> {authResult}</p>
  <p><strong>firebase-admin/storage:</strong> {storageResult}</p>
  <p><strong>../lib/server/env:</strong> {localEnvResult}</p>
  <p><strong>../lib/server/firebase-admin:</strong> {localFirebaseResult}</p>
</body>
</html>
