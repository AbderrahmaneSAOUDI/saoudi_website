---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import GlobalLightbox from '../components/GlobalLightbox.astro';
import { getFirebaseAdminDb } from '../lib/server/firebase-admin';
import { getCached, setCached } from '../lib/server/cache';
import Icon from '../components/Icon.astro';

// Cache page response at edge CDN for 1 hour, revalidate in background up to 10 minutes
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=600');

let designs: any[] = [];
let companies: string[] = ['Google', 'GDG', 'Freelance', 'Personal'];
let errorMsg = '';

const cacheKeyDesigns = 'designs_list';
const cacheKeyCompanies = 'designs_companies';

const cachedDesigns = getCached<any[]>(cacheKeyDesigns);
const cachedCompanies = getCached<string[]>(cacheKeyCompanies);

if (cachedDesigns && cachedCompanies) {
	designs = cachedDesigns;
	companies = cachedCompanies;
} else {
	try {
		const db = getFirebaseAdminDb();

		// PERF: Run both queries in parallel instead of sequentially.
		// Also use select() to fetch only the fields needed for rendering,
		// reducing Firestore read payload and improving TTFB.
		const [companiesDoc, snapshot] = await Promise.all([
			db.collection("configuration").doc("designs_companies").get(),
			db.collection("designs")
				.select('title', 'imageUrl', 'company', 'date', 'tags')
				.orderBy("date", "desc")
				.get(),
		]);

		if (companiesDoc.exists) {
			companies = companiesDoc.data()?.companies || companies;
		}

		designs = snapshot.docs.map(doc => ({
			id: doc.id,
			...doc.data()
		}));

		setCached(cacheKeyDesigns, designs);
		setCached(cacheKeyCompanies, companies);
	} catch (error: any) {
		console.warn("Failed to fetch designs from Firestore for public page:", error);
		errorMsg = "Degraded mode: Designs are currently offline or unavailable.";
	}
}

// Group designs by company
const designsByCompany: Record<string, any[]> = {};
const personalKey = 'Personal / Freelance';

// Initialize all groups
companies.forEach(co => {
	designsByCompany[co] = [];
});
designsByCompany[personalKey] = [];

// Distribute designs
designs.forEach(design => {
	const co = design.company ? design.company : personalKey;
	if (!designsByCompany[co]) {
		designsByCompany[co] = [];
	}
	designsByCompany[co].push(design);
});

// Filter and sort active company groups
const activeGroups = Object.keys(designsByCompany)
	.filter(co => designsByCompany[co].length > 0)
	.sort((a, b) => {
		if (a === personalKey) return 1;
		if (b === personalKey) return -1;
		
		const indexA = companies.indexOf(a);
		const indexB = companies.indexOf(b);
		if (indexA !== -1 && indexB !== -1) return indexA - indexB;
		return a.localeCompare(b);
	});
---

<BaseLayout title="Designs">
	<div class="mx-auto px-4 sm:px-6 lg:px-8 py-16 max-w-7xl">


		{errorMsg && (
			<div class="mb-10 p-4 rounded-2xl bg-[#EA4335]/10 border border-[#EA4335]/30 text-[#EA4335] text-sm text-center">
				{errorMsg}
			</div>
		)}

		<!-- Grouped Lists: Title, Grid, Title, Grid -->
		<div class="space-y-16">
			{activeGroups.map((companyName, groupIndex) => {
				const groupDesigns = designsByCompany[companyName];
				return (
					<section class="space-y-6 animate-slide-up" style={`animation-delay: ${100 + groupIndex * 100}ms; content-visibility: auto; contain-intrinsic-size: auto 500px;`}>
						<!-- Section Title -->
						<div class="flex items-center justify-between border-b border-white/5 pb-3">
							<div class="flex items-center gap-3">
								<div class="w-1.5 h-6 bg-primary rounded-full"></div>
								<h2 class="font-bold text-white text-xl tracking-tight">{companyName}</h2>
								<span class="text-xs text-white/40 font-semibold bg-white/5 px-2.5 py-0.5 rounded-full border border-white/5">
									{groupDesigns.length}
								</span>
							</div>
							<span class="text-[10px] text-white/30 uppercase tracking-widest font-bold hidden sm:inline">
								{companyName === personalKey ? 'Independent Creations' : 'Company Collaborations'}
							</span>
						</div>

						<!-- Grid of Designs -->
						<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3">
							{groupDesigns.map((design, index) => (
								<div class="animate-card-fade" style={`animation-delay: ${index * 50}ms`}>
									<Card item={design} type="design" />
								</div>
							))}
						</div>
					</section>
				);
			})}

			{designs.length === 0 && !errorMsg && (
				<div class="py-24 text-center text-white/40 bg-surface-container rounded-3xl border border-white/10 flex flex-col items-center justify-center animate-fade-in">
					<div class="p-4 rounded-full bg-primary/10 text-primary mb-4">
						<Icon name="design" size={48} />
					</div>
					<p class="font-bold text-white text-lg">No designs uploaded yet</p>
					<p class="text-xs mt-1 text-white/60 max-w-sm">Please check back later or visit the admin panel to add mockups.</p>
				</div>
			)}
		</div>
	</div>

	<!-- Render Lightbox outside transform scopes -->
	<GlobalLightbox />
</BaseLayout>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(15px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes slide-up {
		from {
			opacity: 0;
			transform: translateY(25px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 0.8s cubic-bezier(0.2, 0, 0.2, 1) forwards;
	}

	.animate-slide-up {
		opacity: 0;
		animation: slide-up 0.6s cubic-bezier(0.2, 0, 0.2, 1) forwards;
	}

	.animate-card-fade {
		opacity: 0;
		animation: slide-up 0.5s cubic-bezier(0.2, 0, 0.2, 1) forwards;
	}
</style>
