---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import GlobalLightbox from '../components/GlobalLightbox.astro';
import { getFirebaseAdminDb } from '../lib/server/firebase-admin';
import { getCached, setCached } from '../lib/server/cache';
import Icon from '../components/Icon.astro';

// Cache page response at edge CDN for 1 hour, revalidate in background up to 10 minutes
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600, stale-while-revalidate=600');

let certificates: any[] = [];
let errorMsg = '';

const cacheKeyCertificates = 'certificates_list';

const cachedCertificates = getCached<any[]>(cacheKeyCertificates);

if (cachedCertificates) {
	certificates = cachedCertificates;
} else {
	try {
		const db = getFirebaseAdminDb();

		// PERF: Use select() to only fetch fields needed for public rendering.
		// Avoids transferring unused admin-only fields, reducing payload.
		const snapshot = await db.collection("certificates")
			.select('title', 'imageUrl', 'issuer', 'date', 'type', 'credentialUrl')
			.orderBy("date", "desc")
			.get();
		certificates = snapshot.docs.map(doc => ({
			id: doc.id,
			...doc.data()
		}));

		setCached(cacheKeyCertificates, certificates);
	} catch (error: any) {
		console.warn("Failed to fetch certificates from Firestore for public page:", error);
		errorMsg = "Degraded mode: Certifications are currently offline or unavailable.";
	}
}

// Group certifications by year
const certificatesByYear: Record<string, any[]> = {};

certificates.forEach(cert => {
	let year = 'Other';
	if (cert.date && typeof cert.date === 'string') {
		const parts = cert.date.split('-');
		if (parts[0] && parts[0].length === 4) {
			year = parts[0];
		}
	}
	if (!certificatesByYear[year]) {
		certificatesByYear[year] = [];
	}
	certificatesByYear[year].push(cert);
});

// Sort years descending
const activeYears = Object.keys(certificatesByYear).sort((a, b) => b.localeCompare(a));
---

<BaseLayout title="Certifications">
	<div class="mx-auto px-4 sm:px-6 lg:px-8 py-16 max-w-7xl">
		{errorMsg && (
			<div class="mb-10 p-4 rounded-2xl bg-[#EA4335]/10 border border-[#EA4335]/30 text-[#EA4335] text-sm text-center">
				{errorMsg}
			</div>
		)}

		<!-- Grouped Lists: Year, Grid -->
		<div class="space-y-16">
			{activeYears.map((year, groupIndex) => {
				const groupCerts = certificatesByYear[year];
				return (
					<section class="space-y-6 animate-slide-up" style={`animation-delay: ${100 + groupIndex * 100}ms; content-visibility: auto; contain-intrinsic-size: auto 500px;`}>
						<!-- Section Title -->
						<div class="flex items-center justify-between border-b border-white/5 pb-3">
							<div class="flex items-center gap-3">
								<div class="w-1.5 h-6 bg-primary rounded-full"></div>
								<h2 class="font-bold text-white text-xl tracking-tight">{year}</h2>
								<span class="text-xs text-white/40 font-semibold bg-white/5 px-2.5 py-0.5 rounded-full border border-white/5">
									{groupCerts.length}
								</span>
							</div>
						</div>

						<!-- Grid of Certificates -->
						<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
							{groupCerts.map((cert, index) => (
								<div class="animate-card-fade animate-fade-in" style={`animation-delay: ${index * 50}ms`}>
									<Card item={cert} type="certificate" />
								</div>
							))}
						</div>
					</section>
				);
			})}

			{certificates.length === 0 && !errorMsg && (
				<div class="py-24 text-center text-white/40 bg-surface-container rounded-3xl border border-white/10 flex flex-col items-center justify-center animate-fade-in">
					<div class="p-4 rounded-full bg-primary/10 text-primary mb-4">
						<Icon name="certifications" size={48} />
					</div>
					<p class="font-bold text-white text-lg">No certifications found</p>
					<p class="text-xs mt-1 text-white/60 max-w-sm">Please check back later or visit the admin panel to add credentials.</p>
				</div>
			)}
		</div>
	</div>

	{/* Render Lightbox outside transform scopes */}
	<GlobalLightbox />
</BaseLayout>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(15px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes slide-up {
		from {
			opacity: 0;
			transform: translateY(25px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 0.8s cubic-bezier(0.2, 0, 0.2, 1) forwards;
	}

	.animate-slide-up {
		opacity: 0;
		animation: slide-up 0.6s cubic-bezier(0.2, 0, 0.2, 1) forwards;
	}

	.animate-card-fade {
		opacity: 0;
		animation: slide-up 0.5s cubic-bezier(0.2, 0, 0.2, 1) forwards;
	}
</style>
