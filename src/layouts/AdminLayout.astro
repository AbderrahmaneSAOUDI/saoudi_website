---
import { Download, Mail, Github, Linkedin, Twitter } from 'lucide-astro';
import { resumeUrl } from '../lib/resume';
import { getRandomColor } from '../lib/colors';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;
const primaryColor = getRandomColor();
---

<!DOCTYPE html>
<html lang="en" style={`--color-primary: ${primaryColor}`}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} - saoudi.online</title>
	</head>
    <body class="">
        <slot />
    </body>
</html>