---
interface Props {
	href: string;
	ariaLabel: string;
	extraClass?: string;
}

const { href, ariaLabel, extraClass = '' } = Astro.props;
---

<a
	href={href}
	aria-label={ariaLabel}
	class={`flex justify-center items-center bg-surface/40 hover:bg-surface-high backdrop-blur-lg border border-white/10 hover:border-white/20 rounded-full w-10 h-10 text-white/70 hover:text-white transition-all hover:-translate-y-0.5 duration-300 ${extraClass}`.trim()}
>
	<slot />
</a>
