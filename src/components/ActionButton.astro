---
interface Props {
	href: string;
	type?: 'primary' | 'surface' | 'header';
	download?: boolean;
	extraClass?: string;
	ariaLabel?: string;
}

const { href, type = 'primary', download = false, extraClass = '', ariaLabel } = Astro.props;

const base = 'inline-flex items-center gap-2 rounded-full font-medium text-white transition-all hover:-translate-y-0.5 duration-300';
const variants = {
	primary: 'bg-primary hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/25 px-6 py-3',
	surface: 'bg-surface-container hover:bg-surface-container-high px-6 py-3 border border-white/10 hover:border-white/20',
	header: 'flex items-center gap-2 bg-primary/80 hover:bg-primary/90 backdrop-blur-lg px-5 py-2 border border-transparent hover:border-white/20 text-sm',
};
const classes = `${base} ${variants[type] ?? variants.primary} ${extraClass}`.trim();
---

<a href={href} class={classes} download={download} aria-label={ariaLabel}>
	<slot />
</a>
