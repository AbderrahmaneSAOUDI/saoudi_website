---
/**
 * PublicFooter Component
 * 
 * Displays the social media contact icon actions and the primary copyright notice.
 * Adheres to strict zero client-side JavaScript guidelines.
 */
import '../styles/global.css';
import SocialIconButton from '../components/SocialIconButton.astro';
import Icon from './Icon.astro';

// Setup list of contact methods and external links
const socialLinks = [
	{ iconName: 'google', href: 'https://gdg.community.dev/u/mcmwd6/', label: 'GDG Profile' },
	{ iconName: 'facebook', href: 'https://www.facebook.com/AbdouSaoudi26', label: 'Facebook' },
	{ iconName: 'telegram', href: 'https://t.me/AbdouSAOUDI', label: 'Telegram', hoverIconName: 'telegram' },
	{ iconName: 'linkedin', href: 'https://www.linkedin.com/in/abderrahmane-saoudi/', label: 'LinkedIn' },
	{ iconName: 'github', href: 'https://github.com/AbderrahmaneSAOUDI', label: 'GitHub', hoverIconName: 'github' },
	{ iconName: 'google', href: 'http://g.dev/Abdou_SAOUDI', label: 'Google Developer Profile' },
];
---

<footer class="bg-surface-container mx-4 my-4 py-8 border-white/10 border-t rounded-3xl">
	<div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
		<div class="flex flex-col justify-center items-center gap-6">
			{/* Grid of contact links */}
			<div class="flex items-center gap-4">
				{socialLinks.map((social) => (
					<SocialIconButton href={social.href} ariaLabel={social.label}>
						<Icon name={social.iconName} size={20} />
						<Icon slot="hover-icon" name={social.hoverIconName || social.iconName} filled size={20} />
					</SocialIconButton>
				))}
			</div>

			{/* Copyright and signature text */}
			<p class="text-white/50 text-sm text-center">
				2026 - all rights reserved to Abderrahmane SAOUDI
			</p>
		</div>
	</div>
</footer>