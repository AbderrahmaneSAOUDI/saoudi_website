---
import '../styles/global.css';
import { GitBranch, Users, MessageCircle, Mail } from '@lucide/astro';
import SocialIconButton from '../components/SocialIconButton.astro';

const socialLinks = [
	{ icon: GitBranch, href: 'https://github.com/AbderrahmaneSAOUDI', label: 'GitHub' },
	{ icon: Users, href: 'https://linkedin.com/in/abderrahmane-saoudi', label: 'LinkedIn' },
	{ icon: MessageCircle, href: 'https://twitter.com/AbderrahmaneSAOUDI', label: 'Twitter' },
	{ icon: Mail, href: 'mailto:contact@saoudi.online', label: 'Email' },
];
---

<footer class="bg-surface-container mx-4 my-4 py-8 border-white/10 border-t rounded-3xl">
	<div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
		<div class="flex flex-col justify-center items-center gap-6">
			<div class="flex items-center gap-4">
				{socialLinks.map((social) => (
					<SocialIconButton href={social.href} ariaLabel={social.label}>
						<social.icon class="w-5 h-5" />
					</SocialIconButton>
				))}
			</div>

			<p class="text-white/50 text-sm text-center">
				2026 - all rights reserved to Abderrahmane SAOUDI
			</p>
		</div>
	</div>
</footer>