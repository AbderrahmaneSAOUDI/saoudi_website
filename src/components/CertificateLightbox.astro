---
/**
 * CertificateLightbox Component
 * 
 * Renders a full-screen image overlay modal for certifications.
 * Uses a pure CSS-only toggle strategy leveraging the URI hash anchor and the
 * CSS `:target` pseudo-selector, satisfying the zero client-side JavaScript requirement.
 */
interface Props {
	certificate: {
		id: string;
		title: string;
		imageUrl: string;
		issuer: string;
	};
}

const { certificate } = Astro.props;
---

<div id={`lightbox-${certificate.id}`} class="lightbox-overlay fixed inset-0 bg-black/95 z-50 flex items-center justify-center p-4">
	<a href="#" class="absolute inset-0 cursor-zoom-out" aria-label="Close Lightbox"></a>
	<div class="relative max-w-5xl max-h-[85vh] z-10 flex flex-col items-center">
		<img
			src={certificate.imageUrl}
			alt={certificate.title}
			class="max-w-full max-h-[80vh] object-contain rounded-2xl shadow-2xl border border-white/10"
			decoding="async"
		/>
		<div class="mt-4 text-center">
			<p class="text-white font-bold text-lg">{certificate.title}</p>
			<p class="text-primary text-xs font-semibold uppercase tracking-wider mt-1">{certificate.issuer}</p>
		</div>
	</div>
</div>

<style is:global>
	/* Hides the lightbox by default with opacity 0 and disables interactions */
	.lightbox-overlay {
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s cubic-bezier(0.2, 0, 0.2, 1);
	}
	/* Activates display when the element ID matches the active URL hash fragment */
	.lightbox-overlay:target {
		opacity: 1;
		pointer-events: auto;
	}
</style>
