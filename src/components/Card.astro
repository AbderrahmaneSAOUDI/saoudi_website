---
/**
 * Card Component
 * 
 * Unified card component that handles rendering both design mockups and professional certifications.
 * Supports both public views and interactive admin workspace grids.
 */
import type { Design, Certificate } from '../types';
import Icon from './Icon.astro';

interface Props {
	item: Design | Certificate;
	type: 'design' | 'certificate';
	isAdmin?: boolean;
	isLoading?: boolean;
}

const { item, type, isAdmin = false, isLoading = false } = Astro.props;
const design = !isLoading && type === 'design' ? (item as Design) : undefined;
const certificate = !isLoading && type === 'certificate' ? (item as Certificate) : undefined;

// Format date dynamically: ISO string -> "Month YYYY" with short month names
const formatDate = (dateStr: string) => {
	if (!dateStr) return '';
	try {
		const parts = dateStr.split('-');
		if (parts.length >= 2) {
			const year = parseInt(parts[0], 10);
			const month = parseInt(parts[1], 10) - 1;
			const date = new Date(year, month, 1);
			if (!isNaN(date.getTime())) {
				return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
			}
		}
		const date = new Date(dateStr);
		if (!isNaN(date.getTime())) {
			return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
		}
	} catch (e) {}
	return dateStr;
};

const formattedDate = formatDate(item.date);
const certType = certificate?.type;

const typeColors = {
	'Online': 'bg-primary/50 border-primary/20 text-white',
	'In-Person': 'bg-[#34A853]/50 border-[#34A853]/20 text-white',
	'Hybrid': 'bg-[#F9AB00]/50 border-[#F9AB00]/20 text-black',
};
---

{isLoading ? (
	<article class="border border-white/10 rounded-3xl p-4 bg-surface-container flex flex-col justify-between h-full">
		<div>
			<div class="aspect-[16/10] rounded-2xl mb-4 skeleton"></div>
			<div class="skeleton h-6 w-3/4 mb-2"></div>
			<div class="flex gap-1.5 mt-2">
				<div class="skeleton h-5 w-16"></div>
				<div class="skeleton h-5 w-12"></div>
				<div class="skeleton h-5 w-10"></div>
			</div>
		</div>
		<div class="mt-4 pt-3 border-t border-white/5 flex justify-between items-center">
			<div class="skeleton h-4 w-20"></div>
			<div class="skeleton h-4 w-16"></div>
		</div>
	</article>
) : null}

{design ? (
	<article
		class={`group border rounded-3xl p-4 transition-all duration-300 flex flex-col justify-between h-full ${
			isAdmin
				? 'design-card border-[#2B2930] bg-[#1D1B20] hover:ring-2 hover:ring-primary/40 cursor-pointer'
				: 'bg-surface-container border-white/10 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-primary/10 hover:ring-2 hover:ring-primary/40'
		}`}
		data-id={isAdmin ? design.id : undefined}
	>
		<div>
			<a
				href={`#lightbox-${design.id}`}
				class="relative aspect-[16/10] rounded-2xl overflow-hidden mb-4 border border-white/10 flex items-center justify-center cursor-pointer image-zoom-trigger block"
			>
				<div class="absolute inset-0 skeleton"></div>
				<img
					src={design.imageUrl}
					alt={design.title}
					class="max-w-full max-h-full object-contain group-hover:scale-[1.03] transition-transform duration-500 relative z-10 opacity-0 transition-opacity duration-300"
					loading="lazy"
					decoding="async"
					onload="this.classList.remove('opacity-0'); this.previousElementSibling?.remove();"
					onerror="this.classList.remove('opacity-0'); this.previousElementSibling?.remove();"
				/>
			</a>

			<h3 class="font-bold text-white text-lg group-hover:text-primary transition-colors line-clamp-1">
				{design.title}
			</h3>

			{design.tags && design.tags.length > 0 && (
				<div class="flex flex-wrap gap-1.5 mt-2">
					{design.tags.map((tag: string) => (
						<span class="text-[10px] text-primary/80 font-bold flex items-center gap-0.5 bg-[#2D2D2D] border border-white/5 px-2 py-0.5 rounded-md">
							<Icon name="tag" size={10} />
							{tag}
						</span>
					))}
				</div>
			)}
		</div>

		<div class="design-card-footer mt-4 pt-3 flex justify-between items-center text-xs border-t border-white/5">
			<span class="text-white/40 flex items-center gap-1 font-medium">
				<Icon name="calendar" size={14} />
				{formattedDate}
			</span>
			{design.company && (
				<span class="company-pill px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase bg-primary/10 border border-primary/20 text-primary">
					{design.company}
				</span>
			)}
		</div>
	</article>
) : null}

{certificate ? (
	<article
		class={`group border rounded-3xl p-5 transition-all duration-300 flex flex-col justify-between h-full ${
			isAdmin
				? 'certificate-card border-[#2B2930] bg-[#1D1B20] hover:ring-2 hover:ring-primary/40 cursor-pointer'
				: 'bg-surface-container border-white/10 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-primary/10 hover:ring-2 hover:ring-primary/40'
		}`}
		data-id={isAdmin ? certificate.id : undefined}
	>
		<div class="space-y-4">
			{certificate.imageUrl ? (
				<div class="relative">
					<a
						href={isAdmin ? undefined : `#lightbox-${certificate.id}`}
						class={`relative aspect-[16/10] rounded-2xl overflow-hidden border border-white/10 flex items-center justify-center cursor-pointer ${!isAdmin ? 'image-zoom-trigger' : ''} block bg-[#1D1B20]`}
					>
						<div class="absolute inset-0 skeleton"></div>
						<img
							src={certificate.imageUrl}
							alt={certificate.title}
							class="max-w-full max-h-full object-contain group-hover:scale-[1.03] transition-transform duration-500 relative z-10 opacity-0 transition-opacity duration-300"
							loading="lazy"
							decoding="async"
							onload="this.classList.remove('opacity-0'); this.previousElementSibling?.remove();"
							onerror="this.classList.remove('opacity-0'); this.previousElementSibling?.remove();"
						/>
					</a>
					{certType && (
						<span class={`absolute top-2.5 right-2.5 z-20 px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase border backdrop-blur-md shadow-sm pointer-events-none select-none ${typeColors[certType as keyof typeof typeColors] || ''}`}>
							{certType}
						</span>
					)}
				</div>
			) : (
				<div class="p-3 w-fit rounded-2xl bg-secondary/10 text-secondary border border-secondary/20 group-hover:scale-110 transition-transform duration-300">
					<Icon name="certifications" size={24} />
				</div>
			)}

			<div>
				<h3 class="font-bold text-white text-lg group-hover:text-primary transition-colors line-clamp-2">
					{certificate.title}
				</h3>
			</div>
		</div>

		<div class="mt-4 pt-3 flex justify-between items-center text-xs border-t border-white/5 text-white/40 font-medium">
			<div class="flex items-center gap-2">
				<span class="flex items-center gap-1">
					<Icon name="calendar" size={14} />
					{formattedDate}
				</span>
				{!certificate.imageUrl && certType && (
					<span class={`px-2 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase border ${typeColors[certType as keyof typeof typeColors] || ''}`}>
						{certType}
					</span>
				)}
				{certificate.credentialUrl && (
					<a
						href={certificate.credentialUrl}
						target="_blank"
						rel="noopener noreferrer"
						class={`transition-all duration-300 cursor-pointer text-white/40 hover:text-primary ${
							isAdmin ? 'stop-propagation' : ''
						}`}
						title="Verify Credential"
					>
						<Icon name="open_in_new" size={14} />
					</a>
				)}
			</div>
			{certificate.issuer && (
				<span class="company-pill px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase bg-primary/10 border border-primary/20 text-primary">
					{certificate.issuer}
				</span>
			)}
		</div>
	</article>
) : null}

<script>
	// Cleanup any skeletons for images that loaded instantly from cache
	const removeSkeletons = () => {
		document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
			if (img instanceof HTMLImageElement && img.complete) {
				img.classList.remove('opacity-0');
				const skeleton = img.previousElementSibling;
				if (skeleton && skeleton.classList.contains('skeleton')) {
					skeleton.remove();
				}
			}
		});
	};

	// Run on DOM content loaded and full load
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', removeSkeletons);
	} else {
		removeSkeletons();
	}
	window.addEventListener('load', removeSkeletons);
</script>
