---
/**
 * Card Component
 * 
 * Unified card component that handles rendering both design mockups and professional certificates.
 * Supports both public views and interactive admin workspace grids.
 */
import { Calendar, Tag, Award, ExternalLink } from '@lucide/astro';
import type { Design, Certificate } from '../types';

interface Props {
	item: Design | Certificate;
	type: 'design' | 'certificate';
	isAdmin?: boolean;
}

const { item, type, isAdmin = false } = Astro.props;

// Format date dynamically: ISO string -> "Month YYYY" with short month names
const formatDate = (dateStr: string) => {
	if (!dateStr) return '';
	try {
		const parts = dateStr.split('-');
		if (parts.length >= 2) {
			const year = parseInt(parts[0], 10);
			const month = parseInt(parts[1], 10) - 1;
			const date = new Date(year, month, 1);
			if (!isNaN(date.getTime())) {
				return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
			}
		}
		const date = new Date(dateStr);
		if (!isNaN(date.getTime())) {
			return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
		}
	} catch (e) {}
	return dateStr;
};

const formattedDate = formatDate(item.date);
const isDesign = type === 'design';
const certType = type === 'certificate' ? (item as Certificate).type : undefined;

const typeColors = {
	'Online': 'bg-primary/50 border-primary/20 text-white',
	'In-Person': 'bg-[#34A853]/50 border-[#34A853]/20 text-white',
	'Hybrid': 'bg-[#F9AB00]/50 border-[#F9AB00]/20 text-black',
};
---

{isDesign ? (
	<article 
		class={`group border rounded-3xl p-4 transition-all duration-300 flex flex-col justify-between h-full ${
			isAdmin 
				? 'design-card border-[#2B2930] bg-[#1D1B20] hover:ring-2 hover:ring-primary/40 cursor-pointer' 
				: 'bg-surface-container border-white/10 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-primary/10 hover:ring-2 hover:ring-primary/40'
		}`}
		data-id={isAdmin ? item.id : undefined}
	>
		<div>
			{/* Image Wrapper: Links to CSS-only Target Lightbox Hash */}
			<a 
				href={`#lightbox-${item.id}`} 
				class="relative aspect-[16/10] rounded-2xl overflow-hidden mb-4 border border-white/10 flex items-center justify-center cursor-pointer image-zoom-trigger block animate-fade-in"
			>
				<img
					src={item.imageUrl}
					alt={item.title}
					class="max-w-full max-h-full object-contain group-hover:scale-[1.03] transition-transform duration-500"
					loading="lazy"
					decoding="async"
				/>
			</a>

			<h3 class="font-bold text-white text-lg group-hover:text-primary transition-colors line-clamp-1">
				{item.title}
			</h3>

			{/* Tags List */}
			{item.tags && item.tags.length > 0 && (
				<div class="flex flex-wrap gap-1.5 mt-2">
					{item.tags.map((tag: string) => (
						<span class="text-[10px] text-primary/80 font-bold flex items-center gap-0.5 bg-[#2D2D2D] border border-white/5 px-2 py-0.5 rounded-md">
							<Tag class="w-2.5 h-2.5 text-primary/60" />
							{tag}
						</span>
					))}
				</div>
			)}
		</div>

		{/* Card Footer: Metadata (Date and Company) */}
		<div class="design-card-footer mt-4 pt-3 flex justify-between items-center text-xs border-t border-white/5">
			<span class="text-white/40 flex items-center gap-1 font-medium">
				<Calendar class="w-3.5 h-3.5" />
				{formattedDate}
			</span>
			{item.company && (
				<span class="company-pill px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase bg-primary/10 border border-primary/20 text-primary">
					{item.company}
				</span>
			)}
		</div>
	</article>
) : (
	<article 
		class={`group border rounded-3xl p-5 transition-all duration-300 flex flex-col justify-between h-full ${
			isAdmin 
				? 'certificate-card border-[#2B2930] bg-[#1D1B20] hover:ring-2 hover:ring-primary/40 cursor-pointer' 
				: 'bg-surface-container border-white/10 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-primary/10 hover:ring-2 hover:ring-primary/40'
		}`}
		data-id={isAdmin ? item.id : undefined}
	>
		<div class="space-y-4">
			{item.imageUrl ? (
				<div class="relative">
					<a 
						href={isAdmin ? undefined : `#lightbox-${item.id}`} 
						class={`relative aspect-[16/10] rounded-2xl overflow-hidden border border-white/10 flex items-center justify-center cursor-pointer ${!isAdmin ? 'image-zoom-trigger' : ''} block animate-fade-in bg-[#1D1B20]`}
					>
						<img
							src={item.imageUrl}
							alt={item.title}
							class="max-w-full max-h-full object-contain group-hover:scale-[1.03] transition-transform duration-500"
							loading="lazy"
							decoding="async"
						/>
					</a>
					{certType && (
						<span class={`absolute top-2.5 right-2.5 z-10 px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase border backdrop-blur-md shadow-sm pointer-events-none select-none ${typeColors[certType as keyof typeof typeColors] || ''}`}>
							{certType}
						</span>
					)}
				</div>
			) : (
				<div class="p-3 w-fit rounded-2xl bg-secondary/10 text-secondary border border-secondary/20 group-hover:scale-110 transition-transform duration-300">
					<Award class="w-6 h-6" />
				</div>
			)}

			<div>
				<h3 class="font-bold text-white text-lg group-hover:text-primary transition-colors line-clamp-2">
					{item.title}
				</h3>
			</div>
		</div>

		{/* Card Footer: Metadata (Date and Issuer) */}
		<div class="mt-4 pt-3 flex justify-between items-center text-xs border-t border-white/5 text-white/40 font-medium">
			<div class="flex items-center gap-2">
				<span class="flex items-center gap-1">
					<Calendar class="w-3.5 h-3.5" />
					{formattedDate}
				</span>
				{!item.imageUrl && certType && (
					<span class={`px-2 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase border ${typeColors[certType as keyof typeof typeColors] || ''}`}>
						{certType}
					</span>
				)}
				{item.credentialUrl && (
					<a 
						href={item.credentialUrl} 
						target="_blank" 
						rel="noopener noreferrer"
						class={`transition-all duration-300 cursor-pointer text-white/40 hover:text-primary ${
							isAdmin ? 'stop-propagation' : ''
						}`}
						title="Verify Credential"
					>
						<ExternalLink class="w-3.5 h-3.5" />
					</a>
				)}
			</div>
			{item.issuer && (
				<span class="company-pill px-2.5 py-0.5 rounded-lg text-[10px] font-bold tracking-wide uppercase bg-primary/10 border border-primary/20 text-primary">
					{item.issuer}
				</span>
			)}
		</div>
	</article>
)}
