---
interface Props {
  id: string;
  name: string;
  label: string;
  type?: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url';
  placeholder?: string;
  required?: boolean;
}

const {
  id,
  name,
  label,
  type = 'text',
  placeholder = '',
  required = false,
} = Astro.props;
---

<div class="flex flex-col gap-2">
  <label 
    class="text-sm font-medium transition-colors duration-200" 
    for={id} 
    style="color:var(--color-primary);"
  >
    {label}
  </label>

  <input
    id={id}
    name={name}
    type={type}
    required={required}
    placeholder={placeholder}
    class="w-full px-4 py-2.5 text-sm rounded-lg border-b-2 transition-all duration-200 focus:outline-none"
    style="background:var(--color-surface-container-high); color:var(--color-google-white); border-color:var(--color-google-light-blue);"
  />
  <style>
    input:focus {
      border-color: var(--color-primary) !important;
      box-shadow: 0 2px 0 0 var(--color-primary);
    }
  </style>
</div>