---
/**
 * PublicHeader Component
 * 
 * Renders the primary navigation header for all public routes.
 * Fetches the active resume download URL server-side from Firestore.
 * Produces ZERO client-side JavaScript as per strict architecture requirements.
 */
import NavItem from '../components/NavItem.astro';
import ActionButton from '../components/ActionButton.astro';
import Icon from './Icon.astro';

// Static resume link used on public routes to keep the homepage edge-safe.
let resumeUrl = '/Abderrahmane_SAOUDI_Resume.pdf';

// Read current request pathname to determine active route highlighting
const { pathname } = Astro.url;

// Define navigation route map
const navLinks = [
	{ href: '/', label: 'Home', iconName: 'home' },
	{ href: '/designs', label: 'Designs', iconName: 'design' },
	{ href: '/certifications', label: 'Certifications', iconName: 'certifications' },
	{ href: '/resume', label: 'Resume', iconName: 'download' },
];
---

<header class="top-0 z-50 sticky">
	<div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
		<div class="flex justify-between items-center h-16">
			{/* Brand Logo Pill Link */}
			<a href="/" class="header-logo items-center bg-surface/40 hover:bg-surface-container-high backdrop-blur-lg px-6 py-2 border border-white/10 rounded-full transition-all hover:-translate-y-0.5 duration-300">
				<span class="font-bold text-primary text-lg">saoudi.online</span>
			</a>

			{/* Main Route Navigation Bar */}
			<nav class="flex items-center">
				<div class="flex items-center bg-surface/40 backdrop-blur-lg px-4 py-2 border border-white/10 rounded-full">
					{navLinks.map((link) => {
						const isActive = pathname === link.href;
						return (
							<NavItem href={link.href} isActive={isActive}>
								<span class="nav-icon">
									<Icon name={link.iconName} filled={isActive} size={16} />
								</span>
								<span class="nav-label">{link.label}</span>
							</NavItem>
						);
					})}
				</div>
			</nav>

			{/* Download Resume Action Pill */}
			<ActionButton href={resumeUrl} type="header" download ariaLabel="Download resume">
				<Icon name="download" size={16} />
				<span class="download-text">Download</span>
			</ActionButton>
		</div>
	</div>
</header>