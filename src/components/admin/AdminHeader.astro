---
import { LogOut } from '@lucide/astro';

interface Props {
	title?: string;
	subtitle?: string;
}

const { title = 'Dashboard', subtitle } = Astro.props;
---

<header
	class="flex flex-row justify-between items-center gap-3 border-b border-[#2B2930] pb-4 md:pb-6 mb-6 md:mb-8"
>
	<div class="min-w-0">
		<div class="flex items-center gap-2 mb-1">
			<span class="w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-[#0F9D58] animate-pulse shrink-0"></span>
			<span
				class="text-[10px] md:text-xs uppercase tracking-widest text-[#4285F4] font-semibold truncate"
			>
				Admin Control Panel
			</span>
		</div>
		<h1 class="text-xl md:text-3xl font-extrabold text-white tracking-tight pl-4 truncate">
			{title}
		</h1>
	</div>

	<div class="flex items-center gap-3 shrink-0">
		<a
			href="/admin/admin_logout"
			class="flex items-center gap-2 px-3 md:px-5 py-2 md:py-2.5 rounded-full text-sm font-semibold transition-all duration-300 border border-[#DB4437]/40 hover:bg-[#DB4437] hover:text-white hover:border-transparent hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[#DB4437]/50"
			aria-label="Sign Out"
		>
			<LogOut class="w-4 h-4 md:hidden" />
			<span class="hidden md:inline">Sign Out</span>
		</a>
	</div>
</header>
