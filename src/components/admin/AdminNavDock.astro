---
import { LayoutDashboard, Briefcase, FolderOpen, Palette, Award, Heart, FileText, Clock, Settings, Plus } from '@lucide/astro';

interface Props {
	currentPath?: string;
}

const { currentPath = '/admin' } = Astro.props;

const navItems = [
	{ label: 'Overview', path: '/admin', icon: LayoutDashboard },
	{ label: 'Experience', path: '/admin/admin_experience', icon: Briefcase },
	{ label: 'Projects', path: '/admin/admin_projects', icon: FolderOpen },
	{ label: 'Designs', path: '/admin/admin_designs', icon: Palette },
	{ label: 'Certificates', path: '/admin/admin_certificates', icon: Award },
	{ label: 'Volunteering', path: '/admin/admin_volunteering', icon: Heart },
	{ label: 'Resume', path: '/admin/admin_resume', icon: FileText },
	{ label: 'Timeline', path: '/admin/admin_timeline', icon: Clock, disabled: true },
];

const createOptions = [
	{ label: 'Experience', path: '/admin/admin_experience', icon: Briefcase },
	{ label: 'Project', path: '/admin/admin_projects', icon: FolderOpen },
	{ label: 'Design', path: '/admin/admin_designs', icon: Palette },
	{ label: 'Certificate', path: '/admin/admin_certificates', icon: Award },
	{ label: 'Volunteering', path: '/admin/admin_volunteering', icon: Heart },
];
---

<div
	id="admin-nav-dock"
	class="admin-dock-wrapper bottom-0 left-1/2 z-50 fixed -translate-x-1/2 w-full px-0"
>
	<!-- Floating Navigation Dock -->
	<div
		class="admin-dock-inner flex items-center gap-2 bg-[#211F26] shadow-2xl px-3 py-2.5 border border-white/10 rounded-t-2xl justify-between"
	>
		<!-- Center Slot: Navigation Links -->
		<nav class="flex items-center gap-0.5 overflow-x-auto scrollbar-hide">
			{
				navItems.map((item) => {
					const isActive =
						item.path === '/admin'
							? currentPath === '/admin' || currentPath === '/admin/'
							: currentPath === item.path;

					return (
						<a
							href={item.disabled ? undefined : item.path}
							class={`flex items-center gap-1.5 px-2.5 py-1.5 rounded-full text-sm font-medium transition-all duration-300 shrink-0 ${
								item.disabled
									? 'text-white/30 cursor-not-allowed'
									: isActive
									? 'bg-primary text-white'
									: 'text-white/70 hover:text-white hover:bg-white/5'
							}`}
							aria-label={item.label}
						>
							<span class="admin-nav-icon">
								<item.icon class="w-4 h-4" />
							</span>
							<span class="admin-nav-label">{item.label}</span>
						</a>
					);
				})
			}
		</nav>

		<!-- Right Slot: FAB with Dropdown -->
		<div class="relative shrink-0">
			<button
				id="create-fab"
				class="admin-fab flex justify-center items-center bg-primary hover:bg-primary/80 shadow-lg rounded-full w-10 h-10 transition-colors"
				aria-label="Create new item"
			>
				<Plus class="w-5 h-5 text-white" />
			</button>

			<!-- Dropdown Menu -->
			<div
				id="create-dropdown"
				class="hidden right-0 bottom-14 z-50 absolute bg-[#211F26] shadow-2xl border border-white/10 rounded-2xl w-48 overflow-hidden"
			>
				<div class="p-2">
					<p class="mb-1 px-3 py-2 text-white/50 text-xs">
						What would you like to create?
					</p>
					{
						createOptions.map((option) => (
							<a
								href={option.path}
								class="flex items-center gap-2.5 hover:bg-white/5 px-3 py-2 rounded-xl text-white/70 hover:text-white text-sm transition-colors"
							>
								<option.icon class="w-4 h-4 text-white/50" />
								{option.label}
							</a>
						))
					}
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	// Vanilla JavaScript for admin navigation dock interactivity
	document.addEventListener('DOMContentLoaded', () => {
		// Element Selectors
		const imageSettingsBtn = document.getElementById('image-settings-btn');
		const createFab = document.getElementById('create-fab');
		const createDropdown = document.getElementById('create-dropdown');
		const imageModalBackdrop = document.getElementById('image-modal-backdrop');
		const imageModal = document.getElementById('image-modal');
		const closeModalBtn = document.getElementById('close-modal-btn');
		const cancelSettingsBtn = document.getElementById('cancel-settings-btn');
		const applySettingsBtn = document.getElementById('apply-settings-btn');
		const qualityValue = document.getElementById('quality-value');

		// Correctly cast input elements for TypeScript property access
		const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement | null;
		const maxWidthInput = document.getElementById('max-width-input') as HTMLInputElement | null;

		// --- Image Settings Modal Controls ---
		const openImageModal = () => {
			imageModalBackdrop?.classList.remove('hidden');
			imageModal?.classList.remove('hidden');
		};

		const closeImageModal = () => {
			imageModalBackdrop?.classList.add('hidden');
			imageModal?.classList.add('hidden');
		};

		imageSettingsBtn?.addEventListener('click', openImageModal);
		imageModalBackdrop?.addEventListener('click', closeImageModal);
		closeModalBtn?.addEventListener('click', closeImageModal);
		cancelSettingsBtn?.addEventListener('click', closeImageModal);
		
		applySettingsBtn?.addEventListener('click', () => {
			// Apply settings logic (e.g. print/save current quality and maximum dimension bounds)
			console.log('Settings applied:', {
				quality: qualitySlider?.value,
				maxWidth: maxWidthInput?.value,
			});
			closeImageModal();
		});

		// Dynamic quality display slider text update
		qualitySlider?.addEventListener('input', (e) => {
			if (qualityValue && e.target) {
				qualityValue.textContent = (e.target as HTMLInputElement).value;
			}
		});

		// --- Floating Action Button & Dropdown Menu ---
		let isDropdownOpen = false;

		const toggleDropdown = () => {
			isDropdownOpen = !isDropdownOpen;
			if (isDropdownOpen) {
				createDropdown?.classList.remove('hidden');
			} else {
				createDropdown?.classList.add('hidden');
			}
		};

		createFab?.addEventListener('click', (e) => {
			e.stopPropagation();
			toggleDropdown();
		});

		// Close dropdown when user clicks anywhere else on the document
		document.addEventListener('click', (e) => {
			if (isDropdownOpen && !createDropdown?.contains(e.target as Node) && e.target !== createFab) {
				isDropdownOpen = false;
				createDropdown?.classList.add('hidden');
			}
		});

		// Close dropdown menu when a creation option is clicked
		createDropdown?.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				isDropdownOpen = false;
				createDropdown?.classList.add('hidden');
			});
		});
	});
</script>
