---
import Icon from '../Icon.astro';

interface Props {
	currentPath?: string;
}

const { currentPath = '/admin' } = Astro.props;

const navItems = [
	{ label: 'Overview', path: '/admin', iconName: 'home' },
	{ label: 'Experience', path: '/admin/admin_experience', iconName: 'experience', disabled: true },
	{ label: 'Projects', path: '/admin/admin_projects', iconName: 'projects', disabled: true },
	{ label: 'Designs', path: '/admin/admin_designs', iconName: 'design' },
	{ label: 'Certifications', path: '/admin/admin_certifications', iconName: 'certifications' },
	{ label: 'Volunteering', path: '/admin/admin_volunteering', iconName: 'business', disabled: true },
	{ label: 'Resume', path: '/admin/admin_resume', iconName: 'document' },
	{ label: 'Timeline', path: '/admin/admin_timeline', iconName: 'calendar', disabled: true },
];
---

<div
	id="admin-nav-dock"
	class="admin-dock-wrapper bottom-0 left-1/2 z-50 fixed -translate-x-1/2 w-full px-0"
>
	<!-- Floating Navigation Dock -->
	<div
		class="admin-dock-inner flex items-center gap-2 bg-[#211F26] shadow-2xl px-3 py-2.5 border border-white/10 rounded-t-2xl justify-center"
	>
		<!-- Center Slot: Navigation Links -->
		<nav class="flex items-center gap-0.5 overflow-x-auto scrollbar-hide">
			{
				navItems.map((item) => {
					const isActive =
						item.path === '/admin'
							? currentPath === '/admin' || currentPath === '/admin/'
							: currentPath === item.path;

					return (
						<a
							href={item.disabled ? undefined : item.path}
							class={`flex items-center gap-1.5 px-2.5 py-1.5 rounded-full text-sm font-medium transition-all duration-300 shrink-0 ${
								item.disabled
									? 'text-white/30 cursor-not-allowed'
									: isActive
									? 'bg-primary text-white'
									: 'text-white/70 hover:text-white hover:bg-white/5'
							}`}
							aria-label={item.label}
						>
							<span class="admin-nav-icon">
								<Icon name={item.iconName} size={16} class="w-4 h-4" />
							</span>
							<span class="admin-nav-label">{item.label}</span>
						</a>
					);
				})
			}
		</nav>
	</div>
</div>
