---
import IconComponent from './Icon.astro';

/**
 * AdminDashboard Component
 * Displays a summary of system status and collection counts for the admin workspace.
 */
interface DashboardMetrics {
  counts: {
    projects: number;
    experience: number;
    designs: number;
    certificates: number;
    volunteering: number;
  };
  adminEmail: string;
  systemStatus: string;
  lastUpdated: string;
}

interface Props {
  metrics: DashboardMetrics;
}

const { metrics } = Astro.props;
const { counts, adminEmail, systemStatus, lastUpdated } = metrics;
---

<div class="text-[#E6E1E5] flex flex-col justify-between">
  <div>

    <!-- System Status Banner -->
    <div class="mb-6 p-4 rounded-2xl bg-[#1D1B20] border border-[#2B2930] flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="p-2.5 rounded-xl bg-[#0F9D58]/10 text-[#0F9D58]">
          <IconComponent name="security" size={24} class="w-6 h-6" />
        </div>
        <div>
          <p class="text-sm font-bold text-white">System Security & Infrastructure</p>
          <p class="text-xs text-[#E6E1E5]/50">Middleware protection is active. Secure cookies are enforced.</p>
        </div>
      </div>
      <div class="flex items-center gap-4 text-xs">
        <span class="px-3 py-1 rounded-full bg-[#211F26] border border-[#2B2930] text-[#E6E1E5]/70">
          Environment: <strong class="text-white">Production</strong>
        </span>
        <span class="px-3 py-1 rounded-full bg-[#0F9D58]/10 text-[#0F9D58] border border-[#0F9D58]/20 font-medium">
          Firestore: {systemStatus}
        </span>
      </div>
    </div>

    <!-- Grid Statistics -->
    <section class="mb-10">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        <!-- Projects Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-primary/40 border border-[#2B2930] group" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="relative p-2.5 rounded-2xl bg-primary/10 text-primary">
              <IconComponent name="projects" size={24} class="w-6 h-6 transition-all duration-200 group-hover:opacity-0 group-hover:scale-90" />
              <IconComponent name="projects" filled size={24} class="absolute top-2.5 left-2.5 w-6 h-6 opacity-0 transition-all duration-200 scale-90 group-hover:opacity-100 group-hover:scale-100" />
            </div>
            <span class="text-2xl font-black text-white">{counts.projects}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Projects</h3>
        </div>

        <!-- Experience Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-[#0F9D58]/40 border border-[#2B2930] group" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="relative p-2.5 rounded-2xl bg-[#0F9D58]/10 text-[#0F9D58]">
              <IconComponent name="experience" size={24} class="w-6 h-6 transition-all duration-200 group-hover:opacity-0 group-hover:scale-90" />
              <IconComponent name="experience" filled size={24} class="absolute top-2.5 left-2.5 w-6 h-6 opacity-0 transition-all duration-200 scale-90 group-hover:opacity-100 group-hover:scale-100" />
            </div>
            <span class="text-2xl font-black text-white">{counts.experience}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Experience</h3>
        </div>

        <!-- Designs Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-[#F4B400]/40 border border-[#2B2930] group" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="relative p-2.5 rounded-2xl bg-[#F4B400]/10 text-[#F4B400]">
              <IconComponent name="design" size={24} class="w-6 h-6 transition-all duration-200 group-hover:opacity-0 group-hover:scale-90" />
              <IconComponent name="design" filled size={24} class="absolute top-2.5 left-2.5 w-6 h-6 opacity-0 transition-all duration-200 scale-90 group-hover:opacity-100 group-hover:scale-100" />
            </div>
            <span class="text-2xl font-black text-white">{counts.designs}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Designs</h3>
        </div>

        <!-- Certifications Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-primary/40 border border-[#2B2930] group" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="relative p-2.5 rounded-2xl bg-primary/10 text-primary">
              <IconComponent name="certifications" size={24} class="w-6 h-6 transition-all duration-200 group-hover:opacity-0 group-hover:scale-90" />
              <IconComponent name="certifications" filled size={24} class="absolute top-2.5 left-2.5 w-6 h-6 opacity-0 transition-all duration-200 scale-90 group-hover:opacity-100 group-hover:scale-100" />
            </div>
            <span class="text-2xl font-black text-white">{counts.certificates}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Certifications</h3>
        </div>

        <!-- Volunteering Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-[#0F9D58]/40 border border-[#2B2930] group" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="relative p-2.5 rounded-2xl bg-[#0F9D58]/10 text-[#0F9D58]">
              <IconComponent name="business" size={24} class="w-6 h-6 transition-all duration-200 group-hover:opacity-0 group-hover:scale-90" />
              <IconComponent name="business" filled size={24} class="absolute top-2.5 left-2.5 w-6 h-6 opacity-0 transition-all duration-200 scale-90 group-hover:opacity-100 group-hover:scale-100" />
            </div>
            <span class="text-2xl font-black text-white">{counts.volunteering}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Volunteering</h3>
        </div>
      </div>
    </section>
  </div>
</div>
