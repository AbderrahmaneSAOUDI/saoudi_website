---
/**
 * AdminDashboard Component
 * Displays a summary of system status and collection counts for the admin workspace.
 */
interface DashboardMetrics {
  counts: {
    projects: number;
    experience: number;
    designs: number;
    certificates: number;
    volunteering: number;
  };
  adminEmail: string;
  systemStatus: string;
  lastUpdated: string;
}

interface Props {
  metrics: DashboardMetrics;
}

const { metrics } = Astro.props;
const { counts, adminEmail, systemStatus, lastUpdated } = metrics;
---

<div class="text-[#E6E1E5] flex flex-col justify-between">
  <div>

    <!-- System Status Banner -->
    <div class="mb-8 p-4 rounded-2xl bg-[#1D1B20] border border-[#2B2930] flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="p-2.5 rounded-xl bg-[#0F9D58]/10 text-[#0F9D58]">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-white">System Security & Infrastructure</p>
          <p class="text-xs text-[#E6E1E5]/50">Middleware protection is active. Secure cookies are enforced.</p>
        </div>
      </div>
      <div class="flex items-center gap-4 text-xs">
        <span class="px-3 py-1 rounded-full bg-[#211F26] border border-[#2B2930] text-[#E6E1E5]/70">
          Environment: <strong class="text-white">Production</strong>
        </span>
        <span class="px-3 py-1 rounded-full bg-[#0F9D58]/10 text-[#0F9D58] border border-[#0F9D58]/20 font-medium">
          Firestore: {systemStatus}
        </span>
      </div>
    </div>

    <!-- Grid Statistics -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
        </svg>
        Content Collections Status
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <!-- Projects Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-primary/40 border border-[#2B2930]" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2.5 rounded-2xl bg-primary/10 text-primary">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <span class="text-2xl font-black text-white">{counts.projects}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Projects</h3>
          <p class="text-xs text-[#E6E1E5]/50 mt-1">Showcase items, links and tags.</p>
        </div>

        <!-- Experience Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-[#0F9D58]/40 border border-[#2B2930]" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2.5 rounded-2xl bg-[#0F9D58]/10 text-[#0F9D58]">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4.674 12a3 3 0 000-4h-1.348a3 3 0 000 4h1.348z" />
              </svg>
            </div>
            <span class="text-2xl font-black text-white">{counts.experience}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Experience</h3>
          <p class="text-xs text-[#E6E1E5]/50 mt-1">Professional timeline events.</p>
        </div>

        <!-- Designs Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-[#F4B400]/40 border border-[#2B2930]" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2.5 rounded-2xl bg-[#F4B400]/10 text-[#F4B400]">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-2xl font-black text-white">{counts.designs}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Designs</h3>
          <p class="text-xs text-[#E6E1E5]/50 mt-1">Figma mockups and image URLs.</p>
        </div>

        <!-- Certifications Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-primary/40 border border-[#2B2930]" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2.5 rounded-2xl bg-primary/10 text-primary">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="text-2xl font-black text-white">{counts.certificates}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Certifications</h3>
          <p class="text-xs text-[#E6E1E5]/50 mt-1">Credential records & links.</p>
        </div>

        <!-- Volunteering Card -->
        <div class="p-5 rounded-3xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:ring-2 hover:ring-[#0F9D58]/40 border border-[#2B2930]" style="background: #1D1B20">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2.5 rounded-2xl bg-[#0F9D58]/10 text-[#0F9D58]">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="text-2xl font-black text-white">{counts.volunteering}</span>
          </div>
          <h3 class="font-bold text-[#E6E1E5]">Volunteering</h3>
          <p class="text-xs text-[#E6E1E5]/50 mt-1">GDG & community efforts.</p>
        </div>
      </div>
    </section>
  </div>
</div>
